---
import BaseLayout from '../layouts/BaseLayout.astro';
import AstroHeader from '../components/AstroHeader.astro';
import AstroFooter from '../components/AstroFooter.astro';
import '../styles/global.css';

const seo = {
  path: 'ai-lead-generation-prompt',
  title: 'AI Lead Generation Prompt (Capture & Qualify Leads Automatically)',
  description: 'Use AI lead generation prompts to capture, qualify, and convert website visitors into leads automatically. Copy proven prompt templates.',
  keywords: 'ai lead generation prompt, lead generation prompt, ai sales prompt, lead capture prompt, lead qualification prompt, ai marketing prompt'
};

const prompts = [
  {
    name: "General Lead Capture",
    prompt: "You are an AI assistant helping capture leads. Ask the visitor what they are looking for, collect their email, and guide them to the next step.",
    color: "blue"
  },
  {
    name: "Service Business Qualification",
    prompt: "Act as a sales assistant. Ask the user about their project, budget range, and timeline. If they are qualified, suggest booking a call.",
    color: "green"
  },
  {
    name: "High-Ticket Filtering",
    prompt: "You are qualifying leads for a premium service. Only proceed if the user has a budget above $5,000 and a clear need. Ask discovery questions to understand their situation before revealing pricing.",
    color: "purple"
  },
  {
    name: "Website Chatbot",
    prompt: "You are a helpful chatbot. Greet the visitor, understand their problem, and guide them to the best service or contact option. Be friendly but efficient.",
    color: "cyan"
  },
  {
    name: "Booking Assistant",
    prompt: "Help the user schedule a call. Ask for their availability, preferred time zone, and what they want to discuss. Confirm booking details clearly before finalizing.",
    color: "amber"
  },
  {
    name: "Email Capture Prompt",
    prompt: "Offer a helpful resource related to the user's interest and ask for their email to send it. Explain the value they'll receive and reassure them about privacy.",
    color: "rose"
  },
  {
    name: "Local Business Inquiry",
    prompt: "Ask the user what service they need and their location. Based on their answers, guide them to request a quote or schedule an in-person consultation.",
    color: "emerald"
  },
  {
    name: "Follow-up Message Generator",
    prompt: "Generate a friendly follow-up message reminding the lead to take action. Reference their previous interest, add urgency without being pushy, and include a clear call-to-action.",
    color: "orange"
  },
  {
    name: "Objection Handling",
    prompt: "Address concerns about price, time, or trust. Acknowledge the objection, provide reassurance with social proof or guarantees, and guide the user back to conversion.",
    color: "red"
  },
  {
    name: "Lead Scoring Prompt",
    prompt: "Based on the user's answers about budget, timeline, authority, and need, classify the lead as high, medium, or low priority. Suggest the appropriate next action for each category.",
    color: "indigo"
  }
];
---

<BaseLayout seo={seo}>
  <AstroHeader />

  <!-- Hero Section -->
  <div class="bg-gradient-to-br from-green-600 via-emerald-700 to-teal-800 text-white py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">
        AI Lead Generation Prompt (Turn Visitors into Leads Automatically)
      </h1>
      <p class="text-xl text-green-100 max-w-2xl mx-auto">
        Capture, qualify, and convert website visitors into leads using AI-powered prompts and automation.
      </p>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 py-12">

    <!-- Intro -->
    <section class="mb-12">
      <p class="text-lg text-gray-700 mb-4">
        Most websites don't have a traffic problem.
      </p>
      <p class="text-lg text-gray-700 mb-4">
        They have a conversion problem.
      </p>
      <p class="text-lg text-gray-700 mb-4">
        Visitors come, browse... and leave without taking action.
      </p>
      <p class="text-lg text-gray-700">
        This guide shows you how to use <strong>AI lead generation prompt</strong> strategies to capture, qualify, and convert leads automatically using AI tools.
      </p>
    </section>

    <!-- What is Section -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">What is an AI Lead Generation Prompt?</h2>
      <p class="text-gray-700 mb-4">
        An <strong>AI lead generation prompt</strong> is a structured instruction given to an AI system (chatbot, assistant, or automation tool) to:
      </p>
      <ul class="list-disc list-inside text-gray-700 space-y-2 mb-4">
        <li>Engage visitors in conversation</li>
        <li>Ask qualifying questions</li>
        <li>Collect contact details</li>
        <li>Guide users toward booking or inquiry</li>
      </ul>
      <p class="text-gray-700">
        Instead of static forms, you create <strong>interactive lead capture systems</strong> that respond intelligently to each visitor.
      </p>
    </section>

    <!-- Prompt Structure -->
    <section class="mb-12 bg-gradient-to-r from-green-50 to-emerald-50 rounded-2xl p-8 border border-green-200">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">AI Lead Generation Prompt Structure</h2>
      <p class="text-gray-700 mb-4">Use this formula for effective lead capture prompts:</p>
      <div class="bg-white rounded-lg p-6 border border-green-300 mb-6 font-mono text-sm text-gray-800">
        Role + Goal + Questions + Qualification Logic + Action
      </div>
      <p class="text-gray-700 mb-4"><strong>Example:</strong></p>
      <div class="bg-white rounded-lg p-4 border border-green-200 text-sm text-gray-700">
        "You are an AI assistant for a service business. Your goal is to qualify leads by asking about their needs, budget, and timeline, then guide them to book a call if they match ideal criteria."
      </div>
    </section>

    <!-- Prompts Grid -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">10 Ready-to-Use AI Lead Generation Prompts</h2>
      <p class="text-center text-gray-600 mb-8">Click any prompt to copy it to your clipboard</p>

      <div class="space-y-4">
        {prompts.map((item, index) => (
          <div class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-lg transition-shadow">
            <div class="flex items-start justify-between gap-4 mb-3">
              <h3 class="text-lg font-bold text-gray-900">
                <span class="text-green-600">{index + 1}.</span> {item.name}
              </h3>
              <button
                class="copy-btn flex-shrink-0 px-4 py-2 bg-green-600 text-white text-sm font-medium rounded-lg hover:bg-green-700 transition-colors"
                data-text={item.prompt}
              >
                Copy
              </button>
            </div>
            <p class="text-gray-700 text-sm leading-relaxed">{item.prompt}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- How to Improve -->
    <section class="mb-12 bg-gradient-to-r from-amber-50 to-yellow-50 rounded-2xl p-8 border border-amber-200">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">How to Improve Your Results</h2>
      <p class="text-gray-700 mb-4">To get better results from any <strong>AI lead generation prompt</strong>:</p>
      <ul class="list-disc list-inside text-gray-700 space-y-2">
        <li>Be specific about the role (sales assistant, consultant, etc.)</li>
        <li>Define clear goals (capture, qualify, book)</li>
        <li>Add constraints (budget, location, timeline)</li>
        <li>Test different prompt variations</li>
        <li>Include follow-up logic for different responses</li>
      </ul>
    </section>

    <!-- How to Use -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">How to Use These Prompts</h2>
      <p class="text-gray-700 mb-4">You can use these prompts with:</p>
      <div class="grid md:grid-cols-2 gap-4 mb-6">
        <div class="bg-gray-50 rounded-lg p-4">
          <h3 class="font-semibold text-gray-900 mb-2">AI Platforms</h3>
          <ul class="text-sm text-gray-700 space-y-1">
            <li>Website chatbots</li>
            <li>AI assistants (ChatGPT, Claude)</li>
            <li>CRM automation tools</li>
            <li>Landing page scripts</li>
          </ul>
        </div>
        <div class="bg-gray-50 rounded-lg p-4">
          <h3 class="font-semibold text-gray-900 mb-2">Best When Connected To</h3>
          <ul class="text-sm text-gray-700 space-y-1">
            <li>Booking tools (Calendly, Cal.com)</li>
            <li>Forms and surveys</li>
            <li>Email systems</li>
            <li>CRM platforms</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Internal Tools -->
    <section class="mb-12 bg-white rounded-2xl border border-gray-200 p-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Improve Your Prompts</h2>
      <div class="grid md:grid-cols-3 gap-4">
        <a href="/tools/text-to-prompt" class="p-4 bg-blue-50 rounded-lg hover:bg-blue-100 transition-colors">
          <h3 class="font-semibold text-blue-900">Prompt Expander</h3>
          <p class="text-sm text-blue-700">Transform basic ideas into detailed prompts</p>
        </a>
        <a href="/tools/text-to-prompt" class="p-4 bg-purple-50 rounded-lg hover:bg-purple-100 transition-colors">
          <h3 class="font-semibold text-purple-900">Text to Prompt</h3>
          <p class="text-sm text-purple-700">Convert descriptions into AI-ready prompts</p>
        </a>
        <a href="/tools/image-to-prompt" class="p-4 bg-pink-50 rounded-lg hover:bg-pink-100 transition-colors">
          <h3 class="font-semibold text-pink-900">Image to Prompt</h3>
          <p class="text-sm text-pink-700">Reverse-engineer images into prompts</p>
        </a>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Frequently Asked Questions</h2>
      <div class="space-y-4">
        <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">What is an AI lead generation prompt?</h3>
          <p class="text-gray-700">
            A structured instruction used to guide AI systems to capture and qualify leads through interactive conversations instead of static forms.
          </p>
        </div>
        <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Can AI replace contact forms?</h3>
          <p class="text-gray-700">
            Yes, AI can significantly improve traditional forms by making them interactive and dynamic, leading to higher completion rates and better lead quality.
          </p>
        </div>
        <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">What tools can I use?</h3>
          <p class="text-gray-700">
            ChatGPT, Claude, custom chatbots, CRM integrations (HubSpot, Salesforce), and automation tools like Zapier or Make.
          </p>
        </div>
        <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Are AI prompts effective for small businesses?</h3>
          <p class="text-gray-700">
            Yes, especially for service businesses that rely on fast responses. AI can engage visitors 24/7 and qualify leads while you sleep.
          </p>
        </div>
      </div>
    </section>

    <!-- Related Pages -->
    <section class="bg-gradient-to-r from-green-600 to-emerald-700 rounded-2xl p-8 text-white">
      <h2 class="text-2xl font-bold mb-6">Related Prompt Templates</h2>
      <div class="grid md:grid-cols-2 gap-4">
        <a href="/ai-chatbot-prompt-template" class="p-4 bg-white/10 rounded-lg hover:bg-white/20 transition-colors">
          <h3 class="font-semibold">AI Chatbot Prompt Template</h3>
          <p class="text-sm text-green-100">Customer support and automation prompts</p>
        </a>
        <a href="/ai-prompt-templates-free" class="p-4 bg-white/10 rounded-lg hover:bg-white/20 transition-colors">
          <h3 class="font-semibold">AI Prompt Templates Free</h3>
          <p class="text-sm text-green-100">Browse our complete prompt library</p>
        </a>
      </div>
    </section>
  </div>

  <AstroFooter />

  <!-- Copy functionality -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const copyButtons = document.querySelectorAll('.copy-btn');

      copyButtons.forEach(button => {
        button.addEventListener('click', async () => {
          const text = button.getAttribute('data-text');

          try {
            await navigator.clipboard.writeText(text);
            const originalText = button.textContent;
            button.textContent = 'Copied!';
            button.classList.remove('bg-green-600', 'hover:bg-green-700');
            button.classList.add('bg-emerald-600');

            setTimeout(() => {
              button.textContent = originalText;
              button.classList.remove('bg-emerald-600');
              button.classList.add('bg-green-600', 'hover:bg-green-700');
            }, 2000);
          } catch (err) {
            console.error('Failed to copy:', err);
          }
        });
      });
    });
  </script>
</BaseLayout>
