---
import BaseLayout from '../layouts/BaseLayout.astro';
import AstroHeader from '../components/AstroHeader.astro';
import AstroFooter from '../components/AstroFooter.astro';
import '../styles/global.css';

const seo = {
  path: 'ai-social-media-prompt',
  title: 'AI Social Media Prompt (Posts That Get Engagement)',
  description: 'Create viral social media content with AI prompts for LinkedIn, Twitter, Instagram, and TikTok. Copy ready-to-use templates.',
  keywords: 'ai social media prompt, social media prompt, linkedin post prompt, twitter prompt ai, instagram caption prompt, tiktok script prompt'
};

const prompts = [
  {
    name: "LinkedIn Thought Leadership",
    prompt: "Write a LinkedIn post about [topic]. Start with a bold, contrarian hook that stops the scroll. Use short paragraphs (1-2 sentences max). Include a personal story or observation. End with a question that invites discussion. No hashtags in the body.",
    platform: "LinkedIn",
    color: "blue"
  },
  {
    name: "Twitter/X Thread Starter",
    prompt: "Create a Twitter thread about [topic]. First tweet must hook immediately with a surprising stat, bold claim, or relatable problem. Each tweet should be under 280 characters and end with a reason to keep reading. Include a clear takeaway in the final tweet.",
    platform: "Twitter/X",
    color: "sky"
  },
  {
    name: "Instagram Carousel Script",
    prompt: "Write an Instagram carousel (10 slides) about [topic]. Slide 1: Bold hook that creates curiosity. Slides 2-9: One key point per slide with minimal text. Slide 10: Clear CTA. Keep each slide under 30 words. Make it swipe-worthy.",
    platform: "Instagram",
    color: "pink"
  },
  {
    name: "TikTok Hook Generator",
    prompt: "Generate 5 TikTok video hooks for [topic]. Each hook should be under 3 seconds when spoken. Use pattern interrupts, controversial takes, or relatable struggles. Make viewers think 'wait, what?' in the first second.",
    platform: "TikTok",
    color: "purple"
  },
  {
    name: "LinkedIn Story Post",
    prompt: "Write a LinkedIn post sharing a professional lesson. Structure: 1) Set the scene (1 sentence), 2) The challenge or mistake, 3) What happened, 4) The lesson learned, 5) How others can apply it. Keep it under 1300 characters.",
    platform: "LinkedIn",
    color: "blue"
  },
  {
    name: "Twitter Engagement Bait",
    prompt: "Create a tweet that encourages replies about [topic]. Use formats like: 'Unpopular opinion:', 'Hot take:', 'The best [X] is [controversial answer]. Fight me.', or 'Reply with your [X] and I'll tell you [Y]'. Make it genuinely interesting, not just clickbait.",
    platform: "Twitter/X",
    color: "sky"
  },
  {
    name: "Instagram Caption (Personal Brand)",
    prompt: "Write an Instagram caption for a [type of photo]. Start with a hook, share a brief story or insight, and end with a question or CTA. Keep it conversational and authentic. Add 3-5 relevant hashtags at the end.",
    platform: "Instagram",
    color: "pink"
  },
  {
    name: "YouTube Shorts Script",
    prompt: "Write a 60-second YouTube Shorts script about [topic]. Open with a hook in the first 2 seconds. Deliver value fast with no fluff. Use simple language. End with a surprising twist or clear takeaway. Include visual cues in brackets.",
    platform: "YouTube",
    color: "red"
  },
  {
    name: "LinkedIn Poll + Context",
    prompt: "Create a LinkedIn poll about [topic] with 4 options. Write a short intro (2-3 sentences) that makes people want to vote and share their reasoning in comments. Make options specific enough to spark debate.",
    platform: "LinkedIn",
    color: "blue"
  },
  {
    name: "Twitter Value Thread",
    prompt: "Write a Twitter thread teaching [skill/concept]. Tweet 1: Promise what they'll learn. Tweets 2-8: One actionable tip per tweet with specific examples. Tweet 9: Quick summary. Tweet 10: CTA to follow for more. Make each tweet standalone valuable.",
    platform: "Twitter/X",
    color: "sky"
  }
];
---

<BaseLayout seo={seo}>
  <AstroHeader />

  <!-- Hero Section -->
  <div class="bg-gradient-to-br from-pink-500 via-purple-600 to-indigo-700 text-white py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">
        AI Social Media Prompt (Posts That Get Engagement)
      </h1>
      <p class="text-xl text-pink-100 max-w-2xl mx-auto">
        Stop staring at blank screens. Create scroll-stopping content for LinkedIn, Twitter, Instagram, and TikTok.
      </p>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 py-12">

    <!-- Intro -->
    <section class="mb-12">
      <p class="text-lg text-gray-700 mb-4">
        The algorithm doesn't care how long you spent on a post.
      </p>
      <p class="text-lg text-gray-700 mb-4">
        It cares about engagement. Hooks. Scroll-stopping first lines.
      </p>
      <p class="text-lg text-gray-700">
        This guide gives you <strong>AI social media prompt</strong> templates that create content people actually want to read, share, and engage with.
      </p>
    </section>

    <!-- What is Section -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">What is an AI Social Media Prompt?</h2>
      <p class="text-gray-700 mb-4">
        An <strong>AI social media prompt</strong> is a structured instruction that helps AI create platform-optimized content. Each platform has different:
      </p>
      <ul class="list-disc list-inside text-gray-700 space-y-2 mb-4">
        <li>Character limits and formats</li>
        <li>Audience expectations</li>
        <li>Algorithm preferences</li>
        <li>Engagement patterns</li>
      </ul>
      <p class="text-gray-700">
        Generic prompts create generic content. Platform-specific prompts create content that performs.
      </p>
    </section>

    <!-- Prompt Structure -->
    <section class="mb-12 bg-gradient-to-r from-pink-50 to-purple-50 rounded-2xl p-8 border border-pink-200">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Social Media Prompt Structure</h2>
      <p class="text-gray-700 mb-4">Use this formula for high-engagement content:</p>
      <div class="bg-white rounded-lg p-6 border border-pink-300 mb-6 font-mono text-sm text-gray-800">
        Platform + Format + Topic + Hook Style + Structure + CTA
      </div>
      <p class="text-gray-700 mb-4"><strong>Example:</strong></p>
      <div class="bg-white rounded-lg p-4 border border-pink-200 text-sm text-gray-700">
        "Write a LinkedIn post about remote work productivity. Start with a contrarian hook. Use short paragraphs. Share a personal example. End with a question."
      </div>
    </section>

    <!-- Prompts Grid -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">10 AI Social Media Prompts by Platform</h2>
      <p class="text-center text-gray-600 mb-8">Click any prompt to copy it to your clipboard</p>

      <div class="space-y-4">
        {prompts.map((item, index) => (
          <div class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-lg transition-shadow">
            <div class="flex items-start justify-between gap-4 mb-3">
              <div>
                <span class="text-xs font-medium text-purple-600 uppercase tracking-wide">{item.platform}</span>
                <h3 class="text-lg font-bold text-gray-900">
                  {index + 1}. {item.name}
                </h3>
              </div>
              <button
                class="copy-btn flex-shrink-0 px-4 py-2 bg-purple-600 text-white text-sm font-medium rounded-lg hover:bg-purple-700 transition-colors"
                data-text={item.prompt}
              >
                Copy
              </button>
            </div>
            <p class="text-gray-700 text-sm leading-relaxed">{item.prompt}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- How to Improve -->
    <section class="mb-12 bg-gradient-to-r from-amber-50 to-yellow-50 rounded-2xl p-8 border border-amber-200">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">How to Improve Your Results</h2>
      <p class="text-gray-700 mb-4">Get better social content from any <strong>AI social media prompt</strong>:</p>
      <ul class="list-disc list-inside text-gray-700 space-y-2">
        <li>Specify your niche and target audience</li>
        <li>Include your unique voice or brand tone</li>
        <li>Add examples of posts you admire</li>
        <li>Request multiple variations to test</li>
        <li>Ask for platform-specific formatting</li>
      </ul>
    </section>

    <!-- Internal Tools -->
    <section class="mb-12 bg-white rounded-2xl border border-gray-200 p-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Improve Your Prompts</h2>
      <div class="grid md:grid-cols-3 gap-4">
        <a href="/tools/text-to-prompt" class="p-4 bg-purple-50 rounded-lg hover:bg-purple-100 transition-colors">
          <h3 class="font-semibold text-purple-900">Prompt Expander</h3>
          <p class="text-sm text-purple-700">Transform ideas into detailed prompts</p>
        </a>
        <a href="/tools/text-to-prompt" class="p-4 bg-blue-50 rounded-lg hover:bg-blue-100 transition-colors">
          <h3 class="font-semibold text-blue-900">Text to Prompt</h3>
          <p class="text-sm text-blue-700">Convert topics into AI-ready prompts</p>
        </a>
        <a href="/tools/image-to-prompt" class="p-4 bg-pink-50 rounded-lg hover:bg-pink-100 transition-colors">
          <h3 class="font-semibold text-pink-900">Image to Prompt</h3>
          <p class="text-sm text-pink-700">Create captions from images</p>
        </a>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Frequently Asked Questions</h2>
      <div class="space-y-4">
        <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Will AI-generated posts sound robotic?</h3>
          <p class="text-gray-700">
            Only if you use generic prompts. Add your voice, edit the output, and include personal stories to make content authentic.
          </p>
        </div>
        <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Which platform should I focus on?</h3>
          <p class="text-gray-700">
            Start with one platform where your audience already exists. Master it before expanding. LinkedIn for B2B, Instagram for visual brands, Twitter for thought leadership.
          </p>
        </div>
        <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">How do I make hooks better?</h3>
          <p class="text-gray-700">
            Study viral posts in your niche. Use curiosity gaps, contrarian takes, specific numbers, or relatable struggles. Test different styles.
          </p>
        </div>
      </div>
    </section>

    <!-- Related Pages -->
    <section class="bg-gradient-to-r from-purple-600 to-pink-600 rounded-2xl p-8 text-white">
      <h2 class="text-2xl font-bold mb-6">Related Prompt Templates</h2>
      <div class="grid md:grid-cols-2 gap-4">
        <a href="/ai-blog-writing-prompt" class="p-4 bg-white/10 rounded-lg hover:bg-white/20 transition-colors">
          <h3 class="font-semibold">AI Blog Writing Prompt</h3>
          <p class="text-sm text-purple-100">SEO-optimized blog content</p>
        </a>
        <a href="/ai-prompt-templates-free" class="p-4 bg-white/10 rounded-lg hover:bg-white/20 transition-colors">
          <h3 class="font-semibold">AI Prompt Templates Free</h3>
          <p class="text-sm text-purple-100">Browse all prompt categories</p>
        </a>
      </div>
    </section>
  </div>

  <AstroFooter />

  <!-- Copy functionality -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const copyButtons = document.querySelectorAll('.copy-btn');

      copyButtons.forEach(button => {
        button.addEventListener('click', async () => {
          const text = button.getAttribute('data-text');

          try {
            await navigator.clipboard.writeText(text);
            const originalText = button.textContent;
            button.textContent = 'Copied!';
            button.classList.remove('bg-purple-600', 'hover:bg-purple-700');
            button.classList.add('bg-green-600');

            setTimeout(() => {
              button.textContent = originalText;
              button.classList.remove('bg-green-600');
              button.classList.add('bg-purple-600', 'hover:bg-purple-700');
            }, 2000);
          } catch (err) {
            console.error('Failed to copy:', err);
          }
        });
      });
    });
  </script>
</BaseLayout>
