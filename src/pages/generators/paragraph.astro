---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AstroHeader from '../../components/AstroHeader.astro';
import AstroFooter from '../../components/AstroFooter.astro';
import SimpleGenerator from '../../components/SimpleGenerator';
import CreatorSidebar from '../../components/CreatorSidebar';
import '../../styles/global.css';
import { getSEOData } from '../../data/seo';

const seo = getSEOData('randomParagraphGenerator');
---

<BaseLayout seo={seo}>
  <AstroHeader />

  <!-- Hero Section -->
  <div class="bg-gradient-to-r from-blue-600 to-purple-600 text-white py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        Random Paragraph Generator
      </h1>

      <p class="text-lg opacity-90 mb-8 max-w-2xl mx-auto">
        {seo.description}
      </p>
    </div>
  </div>

  <!-- Main Content with Sidebar -->
  <div class="max-w-7xl mx-auto px-4 py-8">
    <div class="flex flex-col lg:flex-row gap-8">
      {/* Main Content - 70% width on desktop */}
      <div class="flex-1 lg:w-[70%]">
        <SimpleGenerator client:load generatorKey="random-paragraph-generator" />

        <!-- Upgrade CTA Banner (shown after 3 generate clicks) -->
        <div id="upgrade-cta-banner" class="hidden mt-4 mb-2">
          <div class="bg-gradient-to-r from-blue-50 to-purple-50 border border-blue-200 rounded-xl p-4 flex flex-col sm:flex-row items-center justify-between gap-3">
            <p class="text-gray-700 text-sm font-medium">Like these prompts? Get unlimited saves, export to PDF, and 50+ exclusive generators with Pro.</p>
            <a href="/pricing" class="flex-shrink-0 inline-flex items-center gap-1 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors whitespace-nowrap">
              See plans
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>

      {/* Sidebar - 30% width on desktop, appears below on mobile */}
      <aside class="lg:w-[30%] flex-shrink-0">
        <CreatorSidebar client:load />
      </aside>
    </div>
  </div>

  <AstroFooter />

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const storageKey = 'promptCount_paragraph';
      localStorage.setItem(storageKey, '0');

      const banner = document.getElementById('upgrade-cta-banner');

      document.addEventListener('click', (e) => {
        const btn = (e.target as Element).closest('button');
        if (!btn) return;
        const text = btn.textContent?.trim() || '';
        if (text.includes('Generate') && !text.includes('Copy')) {
          let count = parseInt(localStorage.getItem(storageKey) || '0');
          count++;
          localStorage.setItem(storageKey, count.toString());
          if (count >= 3 && banner) {
            banner.classList.remove('hidden');
          }
        }
      });
    });
  </script>
</BaseLayout>
