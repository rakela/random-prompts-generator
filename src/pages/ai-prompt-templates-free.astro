---
import BaseLayout from '../layouts/BaseLayout.astro';
import AstroHeader from '../components/AstroHeader.astro';
import AstroFooter from '../components/AstroFooter.astro';
import '../styles/global.css';

const seo = {
  path: 'ai-prompt-templates-free',
  title: 'AI Prompt Templates Free (Best Prompts for Any Use Case)',
  description: 'Browse free AI prompt templates for content, images, business, and automation. Copy and use instantly.',
  keywords: 'ai prompt templates free, free ai prompts, chatgpt prompt templates, midjourney prompts free, ai prompt library, free prompt templates'
};

const imagePrompts = [
  {
    title: "AI LinkedIn Headshot Prompt",
    description: "Professional profile photos for LinkedIn",
    url: "/ai-linkedin-headshot-prompt"
  },
  {
    title: "AI Corporate Headshot Generator",
    description: "Executive-quality business portraits",
    url: "/ai-corporate-headshot-generator-prompt"
  },
  {
    title: "Studio Ghibli AI Prompt",
    description: "Miyazaki-inspired anime scenes",
    url: "/studio-ghibli-ai-prompt"
  },
  {
    title: "Cinematic Lighting AI Prompt",
    description: "Film-quality dramatic lighting",
    url: "/cinematic-lighting-ai-prompt"
  },
  {
    title: "Double Exposure AI Prompt",
    description: "Surreal portrait blend effects",
    url: "/double-exposure-ai-prompt"
  },
  {
    title: "AI Product Photography Prompt",
    description: "E-commerce and commercial photos",
    url: "/ai-product-photography-prompt"
  },
  {
    title: "Midjourney Prompt Generator",
    description: "V6-optimized templates",
    url: "/midjourney-prompt-generator"
  },
  {
    title: "AI Image Prompt Generator",
    description: "Universal formulas for any art style",
    url: "/ai-prompt-generator-for-images"
  }
];

const businessPrompts = [
  {
    title: "AI Lead Generation Prompt",
    description: "Capture and qualify leads automatically",
    url: "/ai-lead-generation-prompt"
  },
  {
    title: "AI Chatbot Prompt Template",
    description: "Customer support and automation",
    url: "/ai-chatbot-prompt-template"
  }
];

const contentPrompts = [
  {
    title: "AI Social Media Prompt",
    description: "LinkedIn, Twitter, Instagram posts",
    url: "/ai-social-media-prompt"
  },
  {
    title: "AI Blog Writing Prompt",
    description: "SEO-optimized blog content",
    url: "/ai-blog-writing-prompt"
  }
];

const examplePrompts = [
  {
    category: "LinkedIn Post",
    prompt: "Write a LinkedIn post based on this topic with a strong hook, short paragraphs, and a call-to-action that encourages engagement."
  },
  {
    category: "Portrait Photo",
    prompt: "Generate a realistic portrait with cinematic lighting, professional styling, shallow depth of field, and high-end fashion magazine quality."
  },
  {
    category: "Sales Assistant",
    prompt: "Act as a sales assistant and qualify leads based on budget, timeline, and intent. Guide qualified leads to booking."
  },
  {
    category: "Blog Writing",
    prompt: "Write an SEO-optimized blog post about [topic] with a compelling introduction, clear headings, and actionable takeaways."
  },
  {
    category: "Customer Support",
    prompt: "You are a support assistant. Answer questions clearly, guide users to solutions step by step, and escalate complex issues to human support."
  }
];
---

<BaseLayout seo={seo}>
  <AstroHeader />

  <!-- Hero Section -->
  <div class="bg-gradient-to-br from-indigo-600 via-purple-700 to-pink-700 text-white py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">
        AI Prompt Templates Free (Ready-to-Use Prompts for Any Task)
      </h1>
      <p class="text-xl text-purple-100 max-w-2xl mx-auto">
        Skip the guesswork and get better results instantly with our free AI prompt templates.
      </p>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 py-12">

    <!-- Intro -->
    <section class="mb-12">
      <p class="text-lg text-gray-700 mb-4">
        Writing good prompts is the hardest part of using AI.
      </p>
      <p class="text-lg text-gray-700">
        This page gives you <strong>AI prompt templates free</strong> so you can skip the guesswork and get better results instantly.
      </p>
    </section>

    <!-- Image Prompts -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Image Prompts</h2>
      <p class="text-gray-600 mb-4">For Midjourney, DALL-E, Stable Diffusion, and ChatGPT images</p>
      <div class="grid md:grid-cols-2 gap-4">
        {imagePrompts.map((item) => (
          <a href={item.url} class="group bg-white rounded-xl border border-gray-200 p-5 hover:shadow-lg hover:border-purple-300 transition-all">
            <h3 class="font-bold text-gray-900 group-hover:text-purple-700 transition-colors mb-1">
              {item.title}
            </h3>
            <p class="text-sm text-gray-600">{item.description}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- Business Prompts -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Business Prompts</h2>
      <p class="text-gray-600 mb-4">For ChatGPT, Claude, and automation tools</p>
      <div class="grid md:grid-cols-2 gap-4">
        {businessPrompts.map((item) => (
          <a href={item.url} class="group bg-white rounded-xl border border-gray-200 p-5 hover:shadow-lg hover:border-green-300 transition-all">
            <h3 class="font-bold text-gray-900 group-hover:text-green-700 transition-colors mb-1">
              {item.title}
            </h3>
            <p class="text-sm text-gray-600">{item.description}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- Content Prompts Section -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Content Prompts</h2>
      <p class="text-gray-600 mb-4">For blog writing, social media, and SEO</p>
      <div class="grid md:grid-cols-2 gap-4">
        {contentPrompts.map((item) => (
          <a href={item.url} class="group bg-white rounded-xl border border-gray-200 p-5 hover:shadow-lg hover:border-blue-300 transition-all">
            <h3 class="font-bold text-gray-900 group-hover:text-blue-700 transition-colors mb-1">
              {item.title}
            </h3>
            <p class="text-sm text-gray-600">{item.description}</p>
          </a>
        ))}
        <a href="/ai-blog-post-generator" class="group bg-white rounded-xl border border-gray-200 p-5 hover:shadow-lg hover:border-blue-300 transition-all">
          <h3 class="font-bold text-gray-900 group-hover:text-blue-700 transition-colors mb-1">
            AI Blog Post Generator
          </h3>
          <p class="text-sm text-gray-600">SEO-optimized blog post ideas</p>
        </a>
        <a href="/writing-prompts" class="group bg-white rounded-xl border border-gray-200 p-5 hover:shadow-lg hover:border-blue-300 transition-all">
          <h3 class="font-bold text-gray-900 group-hover:text-blue-700 transition-colors mb-1">
            Writing Prompt Generator
          </h3>
          <p class="text-sm text-gray-600">Creative writing prompts</p>
        </a>
      </div>
    </section>

    <!-- Example Prompts -->
    <section class="mb-12 bg-gradient-to-r from-gray-50 to-slate-100 rounded-2xl p-8 border border-gray-200">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Example Prompts You Can Copy</h2>
      <div class="space-y-4">
        {examplePrompts.map((item) => (
          <div class="bg-white rounded-lg p-4 border border-gray-200">
            <div class="flex items-start justify-between gap-4">
              <div>
                <span class="text-xs font-medium text-purple-600 uppercase tracking-wide">{item.category}</span>
                <p class="text-gray-700 text-sm mt-1">{item.prompt}</p>
              </div>
              <button
                class="copy-btn flex-shrink-0 px-3 py-1.5 bg-purple-600 text-white text-xs font-medium rounded-lg hover:bg-purple-700 transition-colors"
                data-text={item.prompt}
              >
                Copy
              </button>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- How to Use -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">How to Use These Templates</h2>
      <div class="grid md:grid-cols-3 gap-4">
        <div class="bg-gray-50 rounded-lg p-5 text-center">
          <div class="w-10 h-10 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-3">
            <span class="text-purple-600 font-bold">1</span>
          </div>
          <h3 class="font-semibold text-gray-900 mb-1">Copy</h3>
          <p class="text-sm text-gray-600">Click any prompt to copy it</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-5 text-center">
          <div class="w-10 h-10 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-3">
            <span class="text-purple-600 font-bold">2</span>
          </div>
          <h3 class="font-semibold text-gray-900 mb-1">Adjust</h3>
          <p class="text-sm text-gray-600">Customize for your use case</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-5 text-center">
          <div class="w-10 h-10 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-3">
            <span class="text-purple-600 font-bold">3</span>
          </div>
          <h3 class="font-semibold text-gray-900 mb-1">Expand</h3>
          <p class="text-sm text-gray-600">Use our tools for better results</p>
        </div>
      </div>
    </section>

    <!-- Tools -->
    <section class="mb-12 bg-white rounded-2xl border border-gray-200 p-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Prompt Tools</h2>
      <p class="text-gray-600 mb-4">Improve any prompt with our free tools</p>
      <div class="grid md:grid-cols-3 gap-4">
        <a href="/tools/text-to-prompt" class="p-4 bg-blue-50 rounded-lg hover:bg-blue-100 transition-colors">
          <h3 class="font-semibold text-blue-900">Prompt Expander</h3>
          <p class="text-sm text-blue-700">Transform basic ideas into detailed prompts</p>
        </a>
        <a href="/tools/text-to-prompt" class="p-4 bg-purple-50 rounded-lg hover:bg-purple-100 transition-colors">
          <h3 class="font-semibold text-purple-900">Text to Prompt</h3>
          <p class="text-sm text-purple-700">Convert descriptions into AI-ready prompts</p>
        </a>
        <a href="/tools/image-to-prompt" class="p-4 bg-pink-50 rounded-lg hover:bg-pink-100 transition-colors">
          <h3 class="font-semibold text-pink-900">Image to Prompt</h3>
          <p class="text-sm text-pink-700">Reverse-engineer images into prompts</p>
        </a>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Frequently Asked Questions</h2>
      <div class="space-y-4">
        <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Are these prompts really free?</h3>
          <p class="text-gray-700">
            Yes, all prompts on this page are completely free to use. Copy, modify, and use them however you like.
          </p>
        </div>
        <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Which AI tools work with these?</h3>
          <p class="text-gray-700">
            ChatGPT, Claude, Midjourney, DALL-E, Stable Diffusion, and most other AI tools that accept text prompts.
          </p>
        </div>
        <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Can I modify these templates?</h3>
          <p class="text-gray-700">
            Absolutely. These are starting points. Customize them with your specific details, style preferences, and requirements.
          </p>
        </div>
        <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">How do I get better results?</h3>
          <p class="text-gray-700">
            Be specific, add context, and use our Prompt Expander tool to automatically enhance any basic idea into a detailed prompt.
          </p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-gradient-to-r from-purple-600 to-indigo-700 rounded-2xl p-8 text-center text-white">
      <h2 class="text-2xl font-bold mb-4">Ready to Create?</h2>
      <p class="text-purple-100 mb-6">
        Start with any template above or use our tools to generate custom prompts.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/tools/text-to-prompt" class="px-6 py-3 bg-white text-purple-700 font-semibold rounded-lg hover:bg-purple-50 transition-colors">
          Try Prompt Expander
        </a>
        <a href="/tools/image-to-prompt" class="px-6 py-3 border-2 border-white text-white font-semibold rounded-lg hover:bg-white hover:text-purple-700 transition-colors">
          Analyze an Image
        </a>
      </div>
    </section>
  </div>

  <AstroFooter />

  <!-- Copy functionality -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const copyButtons = document.querySelectorAll('.copy-btn');

      copyButtons.forEach(button => {
        button.addEventListener('click', async () => {
          const text = button.getAttribute('data-text');

          try {
            await navigator.clipboard.writeText(text);
            const originalText = button.textContent;
            button.textContent = 'Copied!';
            button.classList.remove('bg-purple-600', 'hover:bg-purple-700');
            button.classList.add('bg-green-600');

            setTimeout(() => {
              button.textContent = originalText;
              button.classList.remove('bg-green-600');
              button.classList.add('bg-purple-600', 'hover:bg-purple-700');
            }, 2000);
          } catch (err) {
            console.error('Failed to copy:', err);
          }
        });
      });
    });
  </script>
</BaseLayout>
