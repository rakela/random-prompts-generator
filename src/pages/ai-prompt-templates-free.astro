---
import BaseLayout from '../layouts/BaseLayout.astro';
import AstroHeader from '../components/AstroHeader.astro';
import AstroFooter from '../components/AstroFooter.astro';
import '../styles/global.css';

const seo = {
  path: 'ai-prompt-templates-free',
  title: 'AI Prompt Templates Free (Complete Library 2024)',
  description: 'Free AI prompt templates for ChatGPT, Midjourney, DALL-E, and Claude. Browse 500+ ready-to-use prompts for images, writing, business, and more.',
  keywords: 'ai prompt templates free, free ai prompts, chatgpt prompt templates, midjourney prompts free, ai prompt library, free prompt templates'
};

const imagePromptCategories = [
  {
    title: "AI LinkedIn Headshot Prompt",
    description: "Professional profile photos for LinkedIn and corporate use",
    url: "/ai-linkedin-headshot-prompt",
    count: "12 prompts",
    color: "blue"
  },
  {
    title: "AI Corporate Headshot Generator",
    description: "Executive-quality business portraits and team photos",
    url: "/ai-corporate-headshot-generator-prompt",
    count: "15 prompts",
    color: "slate"
  },
  {
    title: "Studio Ghibli AI Prompt",
    description: "Miyazaki-inspired anime scenes and magical worlds",
    url: "/studio-ghibli-ai-prompt",
    count: "15 prompts",
    color: "green"
  },
  {
    title: "Cinematic Lighting AI Prompt",
    description: "Film-quality lighting effects and Hollywood aesthetics",
    url: "/cinematic-lighting-ai-prompt",
    count: "15 prompts",
    color: "amber"
  },
  {
    title: "Double Exposure AI Prompt",
    description: "Surreal portrait blends and artistic overlays",
    url: "/double-exposure-ai-prompt",
    count: "15 prompts",
    color: "purple"
  },
  {
    title: "AI Image Prompt Generator",
    description: "Universal formulas and prompts for any art style",
    url: "/ai-prompt-generator-for-images",
    count: "20+ prompts",
    color: "violet"
  }
];

const textPromptCategories = [
  {
    title: "AI Lead Generation Prompt",
    description: "Sales prospecting, cold outreach, and conversion templates",
    url: "/ai-lead-generation-prompt",
    count: "15 prompts",
    color: "emerald"
  },
  {
    title: "AI Chatbot Prompt Template",
    description: "System prompts for customer service and virtual assistants",
    url: "/ai-chatbot-prompt-template",
    count: "15 templates",
    color: "indigo"
  }
];

const toolCategories = [
  {
    title: "Text to Prompt Expander",
    description: "Transform simple ideas into detailed, optimized prompts",
    url: "/tools/text-to-prompt",
    icon: "expand",
    color: "blue"
  },
  {
    title: "Image to Prompt Analyzer",
    description: "Reverse-engineer any image into a reusable prompt",
    url: "/tools/image-to-prompt",
    icon: "analyze",
    color: "purple"
  }
];

const artPromptCategories = [
  { title: "Portrait Prompts", url: "/art-prompts/portrait", color: "rose" },
  { title: "Landscape Prompts", url: "/art-prompts/landscape", color: "green" },
  { title: "Anime Prompts", url: "/art-prompts/anime", color: "pink" },
  { title: "Fantasy Art Prompts", url: "/art-prompts/fantasy-art", color: "purple" },
  { title: "Photography Prompts", url: "/art-prompts/photography", color: "slate" },
  { title: "Surrealism Prompts", url: "/art-prompts/surrealism", color: "indigo" },
  { title: "Oil Painting Prompts", url: "/art-prompts/oil-painting", color: "amber" },
  { title: "Watercolor Prompts", url: "/art-prompts/watercolor", color: "cyan" }
];

const writingPromptCategories = [
  { title: "Story Writing Prompts", url: "/writing-prompts/story", color: "blue" },
  { title: "Creative Writing", url: "/writing-prompts/creative", color: "purple" },
  { title: "Business Writing", url: "/writing-prompts/business", color: "slate" },
  { title: "Blog Writing Prompts", url: "/writing-prompts/blog", color: "green" }
];
---

<BaseLayout seo={seo}>
  <AstroHeader />

  <!-- Hero Section -->
  <div class="bg-gradient-to-br from-indigo-600 via-purple-700 to-pink-700 text-white py-20">
    <div class="max-w-5xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">
        Free AI Prompt Templates
      </h1>
      <p class="text-xl md:text-2xl text-purple-100 max-w-3xl mx-auto mb-8">
        Your complete library of AI prompt templates free to use. 500+ ready-to-copy prompts for ChatGPT, Midjourney, DALL-E, Claude, and Stable Diffusion.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="#image-prompts" class="px-6 py-3 bg-white text-purple-700 font-semibold rounded-lg hover:bg-purple-50 transition-colors">
          Image Prompts
        </a>
        <a href="#text-prompts" class="px-6 py-3 bg-purple-500 text-white font-semibold rounded-lg hover:bg-purple-400 transition-colors">
          Text/Chat Prompts
        </a>
        <a href="#tools" class="px-6 py-3 border-2 border-white text-white font-semibold rounded-lg hover:bg-white hover:text-purple-700 transition-colors">
          Prompt Tools
        </a>
      </div>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-4 py-16">

    <!-- What Are AI Prompt Templates -->
    <section class="mb-16">
      <h2 class="text-3xl font-bold text-gray-900 mb-6 text-center">What Are AI Prompt Templates?</h2>
      <p class="text-lg text-gray-700 mb-4 max-w-3xl mx-auto text-center">
        AI prompt templates are pre-written instructions designed to get the best results from AI tools like ChatGPT, Midjourney, DALL-E, and Claude. Instead of starting from scratch, you copy a proven template and customize it for your needs.
      </p>
      <p class="text-lg text-gray-700 max-w-3xl mx-auto text-center">
        Our free AI prompt templates cover image generation, text writing, business tasks, creative projects, and more. Each template is optimized with the right keywords, structure, and parameters for professional results.
      </p>
    </section>

    <!-- Featured Image Prompt Templates -->
    <section id="image-prompts" class="mb-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-gray-900">AI Image Prompt Templates</h2>
        <span class="text-sm text-gray-500">For Midjourney, DALL-E, Stable Diffusion</span>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {imagePromptCategories.map((category) => (
          <a href={category.url} class="group bg-white rounded-xl border border-gray-200 p-6 hover:shadow-xl hover:border-purple-300 transition-all">
            <div class="flex items-start justify-between mb-3">
              <h3 class="text-lg font-bold text-gray-900 group-hover:text-purple-700 transition-colors">
                {category.title}
              </h3>
              <span class="text-xs bg-purple-100 text-purple-700 px-2 py-1 rounded-full">
                {category.count}
              </span>
            </div>
            <p class="text-gray-600 text-sm mb-4">{category.description}</p>
            <span class="text-purple-600 text-sm font-medium group-hover:text-purple-800">
              Browse templates &rarr;
            </span>
          </a>
        ))}
      </div>
    </section>

    <!-- Text/Business Prompt Templates -->
    <section id="text-prompts" class="mb-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-gray-900">AI Text & Business Prompt Templates</h2>
        <span class="text-sm text-gray-500">For ChatGPT, Claude, Gemini</span>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {textPromptCategories.map((category) => (
          <a href={category.url} class="group bg-white rounded-xl border border-gray-200 p-6 hover:shadow-xl hover:border-green-300 transition-all">
            <div class="flex items-start justify-between mb-3">
              <h3 class="text-lg font-bold text-gray-900 group-hover:text-green-700 transition-colors">
                {category.title}
              </h3>
              <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded-full">
                {category.count}
              </span>
            </div>
            <p class="text-gray-600 text-sm mb-4">{category.description}</p>
            <span class="text-green-600 text-sm font-medium group-hover:text-green-800">
              Browse templates &rarr;
            </span>
          </a>
        ))}
      </div>
    </section>

    <!-- Prompt Tools Section -->
    <section id="tools" class="mb-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">AI Prompt Tools</h2>

      <div class="grid md:grid-cols-2 gap-6">
        {toolCategories.map((tool) => (
          <a href={tool.url} class="group bg-gradient-to-r from-indigo-50 to-purple-50 rounded-xl border border-indigo-200 p-8 hover:shadow-xl transition-all">
            <h3 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-indigo-700 transition-colors">
              {tool.title}
            </h3>
            <p class="text-gray-600 mb-4">{tool.description}</p>
            <span class="inline-flex items-center text-indigo-600 font-medium group-hover:text-indigo-800">
              Try tool &rarr;
            </span>
          </a>
        ))}
      </div>
    </section>

    <!-- Art Style Prompts Grid -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Browse by Art Style</h2>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {artPromptCategories.map((category) => (
          <a href={category.url} class="bg-gray-50 rounded-lg p-4 hover:bg-purple-50 hover:shadow transition-all text-center">
            <span class="text-gray-900 font-medium text-sm">{category.title}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- Writing Prompts Grid -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Writing Prompt Templates</h2>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {writingPromptCategories.map((category) => (
          <a href={category.url} class="bg-gray-50 rounded-lg p-4 hover:bg-blue-50 hover:shadow transition-all text-center">
            <span class="text-gray-900 font-medium text-sm">{category.title}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- Why Use Our Templates -->
    <section class="mb-16 bg-gradient-to-r from-amber-50 to-yellow-50 rounded-2xl p-8 border border-amber-200">
      <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">Why Use Our Free AI Prompt Templates?</h2>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-12 h-12 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Save Hours of Testing</h3>
          <p class="text-sm text-gray-600">Each template has been refined through hundreds of generations to produce optimal results.</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Professional Quality</h3>
          <p class="text-sm text-gray-600">Get results that look like they came from expensive professionals or agencies.</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2" />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Copy & Customize</h3>
          <p class="text-sm text-gray-600">One-click copy, then easily modify for your specific project needs.</p>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-8 text-center">Frequently Asked Questions</h2>

      <div class="space-y-4 max-w-3xl mx-auto">
        <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Are these AI prompt templates really free?</h3>
          <p class="text-gray-700">
            Yes, all prompt templates on this page are completely free to use. Copy them, modify them, use them commercially - no attribution required.
          </p>
        </div>
        <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Which AI tools do these prompts work with?</h3>
          <p class="text-gray-700">
            Our image prompts work with Midjourney, DALL-E 3, Stable Diffusion, Leonardo AI, and ChatGPT image generation. Text prompts work with ChatGPT, Claude, Gemini, and most LLMs.
          </p>
        </div>
        <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">How do I use these templates?</h3>
          <p class="text-gray-700">
            Click the "Copy" button next to any prompt, paste it into your AI tool, and customize any bracketed sections like [YOUR TOPIC] with your specific details. Then generate!
          </p>
        </div>
        <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Can I modify the templates?</h3>
          <p class="text-gray-700">
            Absolutely! These templates are starting points. Feel free to add, remove, or change any elements to better fit your project. Experimentation often leads to the best results.
          </p>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="bg-gradient-to-r from-purple-600 to-indigo-700 rounded-2xl p-8 md:p-12 text-center text-white">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">Ready to Create Amazing AI Content?</h2>
      <p class="text-purple-100 mb-8 max-w-2xl mx-auto">
        Start with any template above or use our AI tools to generate custom prompts from your ideas.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/tools/text-to-prompt" class="px-6 py-3 bg-white text-purple-700 font-semibold rounded-lg hover:bg-purple-50 transition-colors">
          Try Prompt Expander
        </a>
        <a href="/tools/image-to-prompt" class="px-6 py-3 border-2 border-white text-white font-semibold rounded-lg hover:bg-white hover:text-purple-700 transition-colors">
          Analyze an Image
        </a>
      </div>
    </section>

  </div>

  <AstroFooter />
</BaseLayout>
