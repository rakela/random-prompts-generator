---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AstroHeader from '../../components/AstroHeader.astro';
import AstroFooter from '../../components/AstroFooter.astro';
import '../../styles/global.css';
import { getSEOData } from '../../data/seo';

const seo = getSEOData('randomAestheticPromptGenerator');

// Aesthetic Prompts - Full sentences ready for AI art, Pinterest, and photography
const aestheticPrompts = [
  "A cozy Cottagecore aesthetic bedroom with overgrown ivy, sunlight filtering through lace curtains, vintage teacups, warm golden hour lighting, highly detailed.",
  "Dark Academia library scene with leather-bound books stacked on mahogany desks, candlelight casting dramatic shadows, vintage fountain pens, sepia-toned atmosphere.",
  "Y2K nostalgia aesthetic: holographic butterflies, frosted pink lip gloss tubes, flip phone with rhinestones, low-rise jeans flat lay, digital camera with flash, iridescent backgrounds.",
  "Cyberpunk 2077 neon cityscape: rain-slicked streets reflecting pink and cyan neon signs, towering holographic advertisements, chrome and glass skyscrapers, moody night atmosphere.",
  "Vaporwave sunset aesthetic: Miami palm trees silhouetted against gradient pink and purple sky, Greek statue fragments, pixelated sun, retro grid floor, nostalgic 80s vibes.",
  "Fairycore enchanted forest: moss-covered stones, glowing mushroom circles, dewdrops on spider webs, ethereal morning fog, butterfly wings catching light, magical woodland path.",
  "Coquette aesthetic vanity setup: pink satin ribbons, vintage perfume bottles, pearl necklaces, lace details, soft blush tones, feminine and delicate styling, romantic lighting.",
  "Goblincore treasure collection: collected crystals and interesting rocks, forest mushrooms in glass jars, moss terrariums, vintage keys, cozy earth tones, chaotic natural beauty.",
  "Light Academia golden hour: cream-colored poetry books on marble windowsill, French café scene, flowing white linen shirt, classical music sheets, Renaissance painting vibes.",
  "Old Money aesthetic: cashmere sweaters folded perfectly, vintage Cartier watch, leather-bound diary, silver tea service, neutral beige and cream palette, quiet luxury.",
  "Frutiger Aero style: glossy translucent bubbles, nature meeting technology, green leaves through glass surfaces, clean white backgrounds, optimistic 2000s tech aesthetic.",
  "Grunge bedroom aesthetic: band posters on dark walls, fairy lights on exposed brick, vinyl records scattered, combat boots, ripped jeans, moody film photography look.",
  "Soft girl pastel paradise: strawberry milk, teddy bears in pastel sweaters, heart-shaped sunglasses, cloud-shaped pillows, pink and lavender color scheme, cute and cozy.",
  "E-girl gaming setup: LED strip lights in purple and pink, anime figures on shelves, mechanical keyboard with custom keycaps, neon signs, dark room with colorful accents.",
  "Minimalist Scandinavian interior: clean white walls, natural light oak furniture, single monstera leaf in ceramic vase, neutral linen textures, geometric shadows, serene atmosphere.",
  "Ocean core coastal bedroom: seashell collections, driftwood decor, sandy neutral palette, linen curtains billowing, nautical rope details, calming blue accents, beach house vibes.",
  "Romantic academia love letters: pressed flowers between vintage book pages, handwritten cursive on aged paper, wax seal stamps, velvet ribbon bookmarks, candlelit desk scene.",
  "Bohemian wanderlust flat lay: vintage world map, leather travel journal, dreamcatcher, ethnic textile patterns, layered gold jewelry, adventure and freedom aesthetic.",
  "Kawaii Japanese room: Sanrio plushies arranged on pink bedding, bubble tea on cute coaster, pastel stationery collection, anime posters, soft pink lighting, adorable maximalism.",
  "Witchy altar aesthetic: crystal collection with amethyst and rose quartz, tarot cards spread on velvet, dried herbs hanging, black cat silhouette, moon phase wall art, mystical ambiance.",
  "Vintage 70s living room: burnt orange velvet couch, macramé wall hanging, shag carpet, vinyl record player, earth tone color palette, retro sunburst mirror, nostalgic warmth.",
  "Clean girl morning routine: glass skincare bottles, white marble bathroom, fluffy towels, minimalist makeup, slicked-back hair, fresh and dewy aesthetic, wellness vibes.",
  "Indie kid bedroom chaos: thrifted band tees on chair, film camera collection, colorful layered rugs, messy but intentional, iced coffee aesthetic, creative and authentic.",
  "Ethereal angel aesthetic: flowing white fabrics, soft cloud backgrounds, pearl and gold accents, feather details, heavenly glow lighting, delicate and divine atmosphere.",
  "Urban street style corner: graffiti-covered brick wall, vintage sneaker collection, skateboard deck art, city skyline through window, golden hour street photography mood.",
  "Cottagecore baking scene: flour-dusted wooden counter, fresh sourdough bread cooling, ceramic mixing bowls, handwritten recipe cards, gingham apron, warm kitchen sunlight.",
  "Dark romantic Victorian: black lace and velvet textures, antique silver candelabra, dried roses in crystal vase, gothic architecture shadows, dramatic and moody elegance.",
  "Retro diner aesthetic: cherry red vinyl booths, checkered floor tiles, neon open sign, milkshake in tall glass, jukebox corner, 1950s Americana nostalgia.",
  "Plant parent jungle corner: monstera and pothos cascading from shelves, terracotta pot collection, watering can, botanical prints, natural light greenhouse vibes, lush green paradise.",
  "Sunset gradient photography: golden hour silhouettes, pink and orange sky gradients, beach sunset reflection, dreamy horizons, magic hour lighting, ethereal landscape mood."
];
---

<BaseLayout seo={seo}>
  <AstroHeader />

  <!-- Hero Section -->
  <div class="bg-gradient-to-r from-indigo-600 to-purple-600 text-white py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        Random Aesthetic Prompt Generator (For Art, Photography & AI)
      </h1>

      <p class="text-lg opacity-90 mb-8 max-w-2xl mx-auto">
        Generate ready-to-use aesthetic prompts for AI art, Pinterest boards, Instagram content, photography shoots, and moodboards. One click delivers a full, vivid prompt featuring popular aesthetics like Dark Academia, Cottagecore, Y2K, Coquette, and more.
      </p>
    </div>
  </div>

  <!-- Main Content -->
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="max-w-4xl mx-auto">

      <!-- Random Generator Section -->
      <div class="bg-white rounded-2xl shadow-xl p-8 mb-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-4 text-center">Generate Random Aesthetic Prompt</h2>
        <p class="text-gray-600 text-center mb-6">Click to generate a ready-to-use aesthetic prompt for AI art, Pinterest, or photography</p>
        <div class="text-center mb-6">
          <button id="generate-random" class="px-8 py-3 bg-gradient-to-r from-indigo-600 to-purple-600 text-white rounded-lg font-semibold hover:from-indigo-700 hover:to-purple-700 transition-all shadow-lg">
            Generate Random Aesthetic
          </button>
        </div>
        <div id="random-prompt-display" class="hidden bg-gradient-to-r from-indigo-50 to-purple-50 border border-indigo-300 rounded-lg p-6">
          <div class="flex items-start gap-3">
            <div class="flex-1">
              <p class="text-gray-800" id="random-prompt-text"></p>
            </div>
            <button id="copy-random" class="p-2 text-gray-400 hover:text-gray-600 transition-colors flex-shrink-0" title="Copy prompt">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect>
                <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- AI Art Section -->
      <div class="bg-gradient-to-r from-purple-50 to-pink-50 border border-purple-200 rounded-xl p-6 mb-8">
        <h2 class="text-xl font-bold text-gray-900 mb-4">Aesthetic Prompts for AI Art (Midjourney & Gemini)</h2>
        <p class="text-gray-700 mb-4">
          Our random aesthetic generator is perfect for creating prompts for AI image generators like Midjourney, DALL-E, Gemini, and Stable Diffusion. Each generated prompt includes a core aesthetic style combined with specific lighting, mood, and detail descriptors that AI tools understand.
        </p>
        <p class="text-gray-700">
          Simply generate a prompt, copy it with one click, and paste directly into your AI art tool. The prompts are formatted as complete, vivid descriptions—no need to add anything else. Mix aesthetics by generating multiple prompts and combining your favorite elements.
        </p>
      </div>

      <!-- Pinterest & Layouts Section -->
      <div class="bg-gradient-to-r from-rose-50 to-orange-50 border border-rose-200 rounded-xl p-6 mb-8">
        <h2 class="text-xl font-bold text-gray-900 mb-4">Pinterest Boards & Aesthetic Layouts</h2>
        <p class="text-gray-700 mb-4">
          These aesthetic prompts aren't just for drawing—they're perfect for planning <strong>Pinterest aesthetic boards</strong>, mood boards, and social media layouts. Use the generated prompts as themes for your next Pinterest board or as inspiration for curating your Instagram grid aesthetic.
        </p>
        <p class="text-gray-700">
          Content creators use our generator to discover trending aesthetic styles and build cohesive visual identities across platforms. Each prompt describes a complete visual scene you can recreate or search for on Pinterest.
        </p>
      </div>

      <!-- Photography Section -->
      <div class="bg-gradient-to-r from-amber-50 to-yellow-50 border border-amber-200 rounded-xl p-6 mb-8">
        <h2 class="text-xl font-bold text-gray-900 mb-4">Aesthetic Photo Prompts for Photographers</h2>
        <p class="text-gray-700 mb-4">
          Are you a photographer or content creator? Use this tool to generate <strong>aesthetic content prompts</strong> for your next photo shoot. Each prompt includes styling details, color palettes, lighting suggestions, and mood descriptions that translate directly into photography direction.
        </p>
        <p class="text-gray-700">
          From flat lay compositions to environmental portraits, these aesthetic prompts help you plan shoots with cohesive visual themes that perform well on Instagram, Pinterest, and editorial platforms.
        </p>
      </div>

      <!-- About Section with Pinterest/Instagram Keywords -->
      <div class="bg-gradient-to-r from-indigo-50 to-purple-50 rounded-2xl shadow-lg p-8 mb-12 border border-indigo-200">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Popular Aesthetics Included</h2>
        <p class="text-gray-700 mb-4">
          Our generator includes the most popular internet aesthetics that creators search for:
        </p>
        <div class="grid md:grid-cols-3 gap-3 text-sm">
          <div class="bg-white/60 rounded-lg p-3">
            <span class="font-semibold text-purple-700">Dark Academia</span>
            <p class="text-gray-600 text-xs mt-1">Libraries, vintage books, scholarly vibes</p>
          </div>
          <div class="bg-white/60 rounded-lg p-3">
            <span class="font-semibold text-green-700">Cottagecore</span>
            <p class="text-gray-600 text-xs mt-1">Rural charm, baking, wildflowers</p>
          </div>
          <div class="bg-white/60 rounded-lg p-3">
            <span class="font-semibold text-pink-700">Y2K</span>
            <p class="text-gray-600 text-xs mt-1">2000s nostalgia, butterfly clips, chrome</p>
          </div>
          <div class="bg-white/60 rounded-lg p-3">
            <span class="font-semibold text-cyan-700">Cyberpunk</span>
            <p class="text-gray-600 text-xs mt-1">Neon cities, tech noir, dystopian</p>
          </div>
          <div class="bg-white/60 rounded-lg p-3">
            <span class="font-semibold text-violet-700">Vaporwave</span>
            <p class="text-gray-600 text-xs mt-1">Retro tech, gradients, Greek statues</p>
          </div>
          <div class="bg-white/60 rounded-lg p-3">
            <span class="font-semibold text-emerald-700">Fairycore</span>
            <p class="text-gray-600 text-xs mt-1">Enchanted forests, mushrooms, magic</p>
          </div>
          <div class="bg-white/60 rounded-lg p-3">
            <span class="font-semibold text-amber-700">Goblincore</span>
            <p class="text-gray-600 text-xs mt-1">Nature treasures, moss, earthy chaos</p>
          </div>
          <div class="bg-white/60 rounded-lg p-3">
            <span class="font-semibold text-rose-700">Coquette</span>
            <p class="text-gray-600 text-xs mt-1">Ribbons, lace, soft femininity</p>
          </div>
          <div class="bg-white/60 rounded-lg p-3">
            <span class="font-semibold text-stone-700">Old Money</span>
            <p class="text-gray-600 text-xs mt-1">Quiet luxury, cashmere, timeless</p>
          </div>
          <div class="bg-white/60 rounded-lg p-3">
            <span class="font-semibold text-teal-700">Frutiger Aero</span>
            <p class="text-gray-600 text-xs mt-1">Glossy tech, nature meets digital</p>
          </div>
          <div class="bg-white/60 rounded-lg p-3">
            <span class="font-semibold text-gray-700">Grunge</span>
            <p class="text-gray-600 text-xs mt-1">90s rebellion, band tees, moody</p>
          </div>
          <div class="bg-white/60 rounded-lg p-3">
            <span class="font-semibold text-yellow-700">Light Academia</span>
            <p class="text-gray-600 text-xs mt-1">Sunny, poetry, golden hour warmth</p>
          </div>
        </div>
      </div>

      <!-- All Prompts Display -->
      <div class="mt-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">All Aesthetic Prompts</h2>
        <div class="grid gap-4">
          {aestheticPrompts.map((prompt, index) => (
            <div class="bg-gradient-to-r from-indigo-50 to-purple-50 border border-indigo-200 rounded-lg p-4 hover:shadow-md transition-shadow">
              <div class="flex items-start gap-3">
                <div class="flex-shrink-0 w-8 h-8 bg-indigo-600 text-white rounded-full flex items-center justify-center font-semibold text-sm">
                  {index + 1}
                </div>
                <div class="flex-1">
                  <p class="text-gray-700">{prompt}</p>
                </div>
                <button
                  class="copy-btn p-2 text-gray-400 hover:text-gray-600 transition-colors flex-shrink-0"
                  data-text={prompt}
                  title="Copy prompt"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect>
                    <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path>
                  </svg>
                </button>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Browse by Style Section -->
      <div class="mt-16 mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-3 text-center">Browse by Style</h2>
        <p class="text-gray-600 text-center mb-8 max-w-2xl mx-auto">Dive deeper into specific aesthetic styles with curated prompt galleries.</p>
        <div class="grid md:grid-cols-3 gap-6">
          <!-- Coquette -->
          <a href="/prompts/coquette-aesthetic" class="group block bg-gradient-to-br from-pink-100 to-rose-200 rounded-2xl overflow-hidden border border-pink-200 hover:shadow-xl hover:scale-[1.02] transition-all duration-200">
            <div class="aspect-[16/10] bg-gradient-to-br from-pink-300 via-rose-200 to-pink-400 flex items-center justify-center">
              <span class="text-pink-500/60 text-7xl font-serif">C</span>
            </div>
            <div class="p-5">
              <h3 class="text-xl font-bold text-pink-700 mb-1 group-hover:text-pink-800">Coquette Aesthetic</h3>
              <p class="text-pink-600/80 text-sm">Soft pinks, lace, vintage femininity, bows, and pearls. 10 prompts.</p>
            </div>
          </a>
          <!-- Dark Academia -->
          <a href="/prompts/dark-academia-aesthetic" class="group block bg-gradient-to-br from-amber-50 to-stone-200 rounded-2xl overflow-hidden border border-amber-200 hover:shadow-xl hover:scale-[1.02] transition-all duration-200">
            <div class="aspect-[16/10] bg-gradient-to-br from-amber-800 via-stone-700 to-stone-800 flex items-center justify-center">
              <span class="text-amber-400/60 text-7xl font-serif">D</span>
            </div>
            <div class="p-5">
              <h3 class="text-xl font-bold text-amber-800 mb-1 group-hover:text-amber-900">Dark Academia</h3>
              <p class="text-amber-700/80 text-sm">Candlelit libraries, leather-bound books, autumn tones, scholarly moods. 10 prompts.</p>
            </div>
          </a>
          <!-- Cyberpunk -->
          <a href="/prompts/cyberpunk-2077-aesthetic" class="group block bg-gradient-to-br from-gray-800 to-gray-900 rounded-2xl overflow-hidden border border-cyan-500/30 hover:shadow-xl hover:shadow-cyan-500/10 hover:scale-[1.02] transition-all duration-200">
            <div class="aspect-[16/10] bg-gradient-to-br from-cyan-800 via-gray-900 to-pink-800 flex items-center justify-center">
              <span class="text-cyan-400/60 text-7xl font-mono font-bold">2077</span>
            </div>
            <div class="p-5">
              <h3 class="text-xl font-bold text-cyan-400 mb-1 group-hover:text-cyan-300">Cyberpunk 2077</h3>
              <p class="text-gray-400 text-sm">Neon streets, chrome implants, holographic tech, rain-slicked dystopia. 10 prompts.</p>
            </div>
          </a>
        </div>
      </div>

      <!-- FAQ Section -->
      <div class="mt-12 mb-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <div class="bg-white border border-gray-200 rounded-xl p-5">
            <h3 class="font-semibold text-gray-900 mb-2">What makes an art prompt "aesthetic"?</h3>
            <p class="text-gray-600 text-sm">An aesthetic (sometimes spelled esthetic or asthetic by creators) refers to a specific visual style, mood, or vibe that is highly cohesive. Our random aesthetic generator combines subjects with these specific visual moods—like Dark Academia or Vaporwave—to give you a perfectly styled idea for your next drawing, AI art generation, or photography shoot.</p>
          </div>
          <div class="bg-white border border-gray-200 rounded-xl p-5">
            <h3 class="font-semibold text-gray-900 mb-2">Can I use these prompts for Midjourney, DALL-E, or ChatGPT?</h3>
            <p class="text-gray-600 text-sm">Yes! Each prompt is formatted as a complete, vivid description ready to paste directly into any AI image generator. The prompts include lighting, mood, style, and detail descriptors that AI tools understand and render effectively.</p>
          </div>
          <div class="bg-white border border-gray-200 rounded-xl p-5">
            <h3 class="font-semibold text-gray-900 mb-2">How do I use these for Pinterest boards?</h3>
            <p class="text-gray-600 text-sm">Use the generated aesthetic description as a theme for your Pinterest board. Search Pinterest for images matching the described elements, or use the prompt to create AI-generated pins. The cohesive styling makes your boards feel professionally curated.</p>
          </div>
          <div class="bg-white border border-gray-200 rounded-xl p-5">
            <h3 class="font-semibold text-gray-900 mb-2">What aesthetics are included in the generator?</h3>
            <p class="text-gray-600 text-sm">Our generator includes all major internet aesthetics: Dark Academia, Light Academia, Cottagecore, Y2K, Cyberpunk, Vaporwave, Fairycore, Goblincore, Coquette, Grunge, Old Money, Frutiger Aero, Soft Girl, E-girl, Minimalist Scandinavian, Ocean Core, Kawaii, Witchy, and many more.</p>
          </div>
        </div>
      </div>

      <!-- Related Links -->
      <div class="mt-12 bg-gray-50 rounded-lg p-6 border border-gray-200">
        <h3 class="text-xl font-bold text-gray-900 mb-4">More Art & AI Prompts</h3>
        <div class="grid md:grid-cols-2 gap-4">
          <a href="/ai-images-prompt" class="text-indigo-700 hover:underline flex items-center gap-2">
            🎨 AI Art Prompts Generator
          </a>
          <a href="/midjourney-ai-picture-generator" class="text-indigo-700 hover:underline flex items-center gap-2">
            🖼️ Midjourney Prompts
          </a>
          <a href="/tools/instagram-aesthetic-generator" class="text-indigo-700 hover:underline flex items-center gap-2">
            📸 Instagram Aesthetic Generator
          </a>
          <a href="/art-prompts/art-style" class="text-indigo-700 hover:underline flex items-center gap-2">
            🎭 Random Art Style Generator
          </a>
        </div>
      </div>
    </div>
  </div>

  <AstroFooter />

  <!-- Random generator and copy functionality -->
  <script define:vars={{ aestheticPrompts }}>
    const allPrompts = aestheticPrompts;

    document.addEventListener('DOMContentLoaded', () => {
      const copyButtons = document.querySelectorAll('.copy-btn');
      const generateRandomBtn = document.getElementById('generate-random');
      const randomPromptDisplay = document.getElementById('random-prompt-display');
      const copyRandomBtn = document.getElementById('copy-random');

      // Copy functionality for prompt cards
      copyButtons.forEach(button => {
        button.addEventListener('click', async () => {
          const text = button.getAttribute('data-text');
          try {
            await navigator.clipboard.writeText(text);
            const originalHTML = button.innerHTML;
            button.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
            button.classList.add('text-green-600');
            setTimeout(() => {
              button.innerHTML = originalHTML;
              button.classList.remove('text-green-600');
            }, 2000);
          } catch (err) {
            console.error('Failed to copy:', err);
          }
        });
      });

      // Random prompt generator
      generateRandomBtn.addEventListener('click', () => {
        const randomPrompt = allPrompts[Math.floor(Math.random() * allPrompts.length)];

        document.getElementById('random-prompt-text').textContent = randomPrompt;
        randomPromptDisplay.classList.remove('hidden');

        copyRandomBtn.setAttribute('data-text', randomPrompt);
      });

      // Copy random prompt
      copyRandomBtn.addEventListener('click', async () => {
        const text = copyRandomBtn.getAttribute('data-text');
        try {
          await navigator.clipboard.writeText(text);
          const originalHTML = copyRandomBtn.innerHTML;
          copyRandomBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
          copyRandomBtn.classList.add('text-green-600');
          setTimeout(() => {
            copyRandomBtn.innerHTML = originalHTML;
            copyRandomBtn.classList.remove('text-green-600');
          }, 2000);
        } catch (err) {
          console.error('Failed to copy:', err);
        }
      });
    });
  </script>
</BaseLayout>
