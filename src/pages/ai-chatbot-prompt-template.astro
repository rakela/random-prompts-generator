---
import BaseLayout from '../layouts/BaseLayout.astro';
import AstroHeader from '../components/AstroHeader.astro';
import AstroFooter from '../components/AstroFooter.astro';
import '../styles/global.css';

const seo = {
  path: 'ai-chatbot-prompt-template',
  title: 'AI Chatbot Prompt Template (Customer Support & Lead Capture)',
  description: 'Create AI chatbot prompts for customer support, lead capture, and automation. Copy ready-to-use templates.',
  keywords: 'ai chatbot prompt template, chatbot system prompt, ai assistant prompt, customer support bot prompt, chatbot instructions template, lead capture chatbot'
};

const prompts = [
  {
    name: "Customer Support Bot",
    prompt: "You are a support assistant. Answer questions clearly and guide users to solutions step by step. Be helpful, patient, and thorough.",
    color: "blue"
  },
  {
    name: "Lead Capture Bot",
    prompt: "Ask the user what they need, collect their email, and guide them to contact or booking. Be friendly but focused on capturing their information.",
    color: "green"
  },
  {
    name: "Sales Assistant",
    prompt: "Help users choose the right service based on their needs and budget. Highlight benefits, address concerns, and encourage them to take action.",
    color: "purple"
  },
  {
    name: "FAQ Bot",
    prompt: "Answer common questions clearly and briefly. If you don't know the answer, direct users to human support.",
    color: "cyan"
  },
  {
    name: "Booking Bot",
    prompt: "Help users schedule a call or service by collecting their availability, contact info, and any special requirements. Confirm all details before finalizing.",
    color: "amber"
  },
  {
    name: "E-commerce Assistant",
    prompt: "Recommend products based on user preferences, budget, and needs. Help them compare options and guide them toward purchase.",
    color: "pink"
  },
  {
    name: "Local Business Bot",
    prompt: "Ask the user their location and what service they need. Based on their answers, guide them to booking or request a quote.",
    color: "emerald"
  },
  {
    name: "Qualification Bot",
    prompt: "Filter users based on budget, timeline, and intent before continuing the conversation. Route qualified leads to sales and provide resources to others.",
    color: "indigo"
  },
  {
    name: "Onboarding Bot",
    prompt: "Guide new users through setup step by step. Explain each feature clearly, check for understanding, and celebrate their progress.",
    color: "orange"
  },
  {
    name: "Follow-up Bot",
    prompt: "Send friendly reminders and encourage users to complete their action. Reference their previous interest and add a clear call-to-action.",
    color: "rose"
  }
];
---

<BaseLayout seo={seo}>
  <AstroHeader />

  <!-- Hero Section -->
  <div class="bg-gradient-to-br from-blue-600 via-indigo-700 to-purple-800 text-white py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">
        AI Chatbot Prompt Template (Ready-to-Use Prompts for Automation)
      </h1>
      <p class="text-xl text-blue-100 max-w-2xl mx-auto">
        Build smarter chatbots that guide users, qualify leads, and drive conversions.
      </p>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 py-12">

    <!-- Intro -->
    <section class="mb-12">
      <p class="text-lg text-gray-700 mb-4">
        Most chatbots fail because they are too generic.
      </p>
      <p class="text-lg text-gray-700 mb-4">
        They don't guide users. They don't qualify leads. They don't convert.
      </p>
      <p class="text-lg text-gray-700">
        This guide gives you <strong>AI chatbot prompt template</strong> examples you can use to build smarter, more effective chatbots.
      </p>
    </section>

    <!-- What is Section -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">What is an AI Chatbot Prompt Template?</h2>
      <p class="text-gray-700 mb-4">
        An <strong>AI chatbot prompt template</strong> is a predefined instruction that controls how a chatbot:
      </p>
      <ul class="list-disc list-inside text-gray-700 space-y-2 mb-4">
        <li>Responds to users</li>
        <li>Asks questions</li>
        <li>Guides conversations</li>
        <li>Drives actions</li>
      </ul>
      <p class="text-gray-700">
        Instead of random replies, you create <strong>structured conversations</strong> that lead to specific outcomes.
      </p>
    </section>

    <!-- Prompt Structure -->
    <section class="mb-12 bg-gradient-to-r from-blue-50 to-indigo-50 rounded-2xl p-8 border border-blue-200">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">AI Chatbot Prompt Structure</h2>
      <p class="text-gray-700 mb-4">Use this formula for effective chatbot prompts:</p>
      <div class="bg-white rounded-lg p-6 border border-blue-300 mb-6 font-mono text-sm text-gray-800">
        Role + Tone + Goal + Conversation Flow + Output
      </div>
      <p class="text-gray-700 mb-4"><strong>Example:</strong></p>
      <div class="bg-white rounded-lg p-4 border border-blue-200 text-sm text-gray-700">
        "You are a friendly assistant for a service business. Your goal is to understand user needs, ask relevant questions, and guide them to book a service."
      </div>
    </section>

    <!-- Prompts Grid -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">10 Chatbot Prompt Templates</h2>
      <p class="text-center text-gray-600 mb-8">Click any prompt to copy it to your clipboard</p>

      <div class="space-y-4">
        {prompts.map((item, index) => (
          <div class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-lg transition-shadow">
            <div class="flex items-start justify-between gap-4 mb-3">
              <h3 class="text-lg font-bold text-gray-900">
                <span class="text-blue-600">{index + 1}.</span> {item.name}
              </h3>
              <button
                class="copy-btn flex-shrink-0 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors"
                data-text={item.prompt}
              >
                Copy
              </button>
            </div>
            <p class="text-gray-700 text-sm leading-relaxed">{item.prompt}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- How to Improve -->
    <section class="mb-12 bg-gradient-to-r from-amber-50 to-yellow-50 rounded-2xl p-8 border border-amber-200">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">How to Improve Your Results</h2>
      <p class="text-gray-700 mb-4">To get better results from any <strong>AI chatbot prompt template</strong>:</p>
      <ul class="list-disc list-inside text-gray-700 space-y-2">
        <li>Define clear goals (support, qualify, convert)</li>
        <li>Avoid vague or generic prompts</li>
        <li>Guide conversation steps explicitly</li>
        <li>Test different prompt variations</li>
        <li>Add personality that matches your brand</li>
      </ul>
    </section>

    <!-- How to Use -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">How to Use These Templates</h2>
      <p class="text-gray-700 mb-4">You can use these prompts with:</p>
      <div class="grid md:grid-cols-2 gap-4 mb-6">
        <div class="bg-gray-50 rounded-lg p-4">
          <h3 class="font-semibold text-gray-900 mb-2">Chatbot Platforms</h3>
          <ul class="text-sm text-gray-700 space-y-1">
            <li>Website chat widgets</li>
            <li>ChatGPT custom GPTs</li>
            <li>Intercom, Drift, Crisp</li>
            <li>WhatsApp Business</li>
          </ul>
        </div>
        <div class="bg-gray-50 rounded-lg p-4">
          <h3 class="font-semibold text-gray-900 mb-2">Automation Tools</h3>
          <ul class="text-sm text-gray-700 space-y-1">
            <li>CRM workflows</li>
            <li>Zapier / Make automations</li>
            <li>Custom integrations</li>
            <li>Voice assistants</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Internal Tools -->
    <section class="mb-12 bg-white rounded-2xl border border-gray-200 p-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Improve Your Prompts</h2>
      <div class="grid md:grid-cols-3 gap-4">
        <a href="/tools/text-to-prompt" class="p-4 bg-blue-50 rounded-lg hover:bg-blue-100 transition-colors">
          <h3 class="font-semibold text-blue-900">Prompt Expander</h3>
          <p class="text-sm text-blue-700">Transform basic ideas into detailed prompts</p>
        </a>
        <a href="/tools/text-to-prompt" class="p-4 bg-purple-50 rounded-lg hover:bg-purple-100 transition-colors">
          <h3 class="font-semibold text-purple-900">Text to Prompt</h3>
          <p class="text-sm text-purple-700">Convert descriptions into AI-ready prompts</p>
        </a>
        <a href="/tools/image-to-prompt" class="p-4 bg-pink-50 rounded-lg hover:bg-pink-100 transition-colors">
          <h3 class="font-semibold text-pink-900">Image to Prompt</h3>
          <p class="text-sm text-pink-700">Reverse-engineer images into prompts</p>
        </a>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Frequently Asked Questions</h2>
      <div class="space-y-4">
        <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">What is an AI chatbot prompt template?</h3>
          <p class="text-gray-700">
            A structured instruction that defines how a chatbot responds, asks questions, and guides users through conversations toward specific goals.
          </p>
        </div>
        <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Do I need coding skills to use these?</h3>
          <p class="text-gray-700">
            No. Most chatbot platforms let you paste these prompts directly into their system prompt or personality settings without any code.
          </p>
        </div>
        <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Can I customize these templates?</h3>
          <p class="text-gray-700">
            Absolutely! These are starting points. Add your business name, specific services, tone preferences, and any rules you want the bot to follow.
          </p>
        </div>
        <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Which platforms work best with these prompts?</h3>
          <p class="text-gray-700">
            ChatGPT custom GPTs, Claude, Intercom, Drift, and any platform that supports system prompts or personality customization.
          </p>
        </div>
      </div>
    </section>

    <!-- Related Pages -->
    <section class="bg-gradient-to-r from-blue-600 to-indigo-700 rounded-2xl p-8 text-white">
      <h2 class="text-2xl font-bold mb-6">Related Prompt Templates</h2>
      <div class="grid md:grid-cols-2 gap-4">
        <a href="/ai-lead-generation-prompt" class="p-4 bg-white/10 rounded-lg hover:bg-white/20 transition-colors">
          <h3 class="font-semibold">AI Lead Generation Prompt</h3>
          <p class="text-sm text-blue-100">Capture and qualify leads automatically</p>
        </a>
        <a href="/ai-prompt-templates-free" class="p-4 bg-white/10 rounded-lg hover:bg-white/20 transition-colors">
          <h3 class="font-semibold">AI Prompt Templates Free</h3>
          <p class="text-sm text-blue-100">Browse our complete prompt library</p>
        </a>
      </div>
    </section>
  </div>

  <AstroFooter />

  <!-- Copy functionality -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const copyButtons = document.querySelectorAll('.copy-btn');

      copyButtons.forEach(button => {
        button.addEventListener('click', async () => {
          const text = button.getAttribute('data-text');

          try {
            await navigator.clipboard.writeText(text);
            const originalText = button.textContent;
            button.textContent = 'Copied!';
            button.classList.remove('bg-blue-600', 'hover:bg-blue-700');
            button.classList.add('bg-green-600');

            setTimeout(() => {
              button.textContent = originalText;
              button.classList.remove('bg-green-600');
              button.classList.add('bg-blue-600', 'hover:bg-blue-700');
            }, 2000);
          } catch (err) {
            console.error('Failed to copy:', err);
          }
        });
      });
    });
  </script>
</BaseLayout>
