---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AstroHeader from '../../components/AstroHeader.astro';
import AstroFooter from '../../components/AstroFooter.astro';
import CoquetteAestheticPrompts from '../../components/CoquetteAestheticPrompts';
import '../../styles/global.css';

const seo = {
  path: 'prompts/coquette-aesthetic',
  title: 'Coquette Aesthetic AI Prompts — Free Copy-Paste (MidJourney & DALL-E)',
  description: 'Free coquette aesthetic AI image prompts — soft pinks, lace, bows, pearls, and vintage femininity. Copy and paste directly into MidJourney, DALL-E, or Gemini. No signup.',
  keywords: 'coquette aesthetic prompts, coquette ai prompts, pink aesthetic ai, lace aesthetic, vintage feminine prompts, coquette core, ai image prompts, midjourney coquette',
};
---

<BaseLayout seo={seo}>
  <AstroHeader />
  <CoquetteAestheticPrompts client:load />
  <AstroFooter />
</BaseLayout>
