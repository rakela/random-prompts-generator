---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AstroHeader from '../../components/AstroHeader.astro';
import AstroFooter from '../../components/AstroFooter.astro';
import DarkAcademiaPrompts from '../../components/DarkAcademiaPrompts';
import '../../styles/global.css';

const seo = {
  path: 'prompts/dark-academia-aesthetic',
  title: 'Dark Academia AI Prompts — Free Copy-Paste (MidJourney & DALL-E)',
  description: 'Free dark academia AI image prompts — candlelit libraries, leather-bound books, autumn tones, and scholarly atmospheres. Copy directly into MidJourney or DALL-E. No signup.',
  keywords: 'dark academia prompts, dark academia ai, scholarly aesthetic prompts, moody academic ai art, brown gold aesthetic, library aesthetic, midjourney dark academia',
};
---

<BaseLayout seo={seo}>
  <AstroHeader />
  <DarkAcademiaPrompts client:load />
  <AstroFooter />
</BaseLayout>
