---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AstroHeader from '../../components/AstroHeader.astro';
import AstroFooter from '../../components/AstroFooter.astro';

export const prerender = true;

const seo = {
  path: 'tools',
  title: 'AI Tools for Content Creators — YouTube, Prompts & Image Analysis',
  description: 'Professional AI tools to repurpose YouTube videos, expand prompts, analyze images, and generate video scripts. Free trial. No signup needed to start.',
  keywords: 'ai tools, youtube tools, prompt tools, image analyzer, video ai prompts, content creation tools'
};

// Tool cards data
const tools = [
  {
    badge: 'POPULAR',
    badgeColor: 'bg-green-100 text-green-800',
    name: 'YouTube → Blog & LinkedIn',
    description: 'Turn any YouTube video into a content brief, blog post, and LinkedIn post in one workflow.',
    link: '/workflows/youtube-to-blog-and-linkedin'
  },
  {
    badge: 'PRO',
    badgeColor: 'bg-gray-900 text-white',
    name: 'YouTube Content Brief',
    description: 'Extract key takeaways, structure, and insights from any YouTube video instantly.',
    link: '/tools/youtube-content-brief'
  },
  {
    badge: 'PRO',
    badgeColor: 'bg-gray-900 text-white',
    name: 'YouTube Blog Post Generator',
    description: 'Convert a YouTube video transcript into an SEO-optimized blog post ready to publish.',
    link: '/tools/youtube-blog-post-generator'
  },
  {
    badge: 'PRO',
    badgeColor: 'bg-gray-900 text-white',
    name: 'YouTube LinkedIn Post',
    description: 'Generate a professional LinkedIn post from any YouTube video with one click.',
    link: '/tools/youtube-linkedin-post-generator'
  },
  {
    badge: 'NEW',
    badgeColor: 'bg-blue-100 text-blue-800',
    name: 'Prompt Expander',
    description: 'Turn a short idea into a detailed, structured AI prompt or JSON object.',
    link: '/tools/text-to-prompt'
  },
  {
    badge: 'NEW',
    badgeColor: 'bg-blue-100 text-blue-800',
    name: 'Image Analyzer',
    description: 'Upload any AI image and get the prompt that likely generated it — ready to reuse.',
    link: '/tools/image-to-prompt'
  },
  {
    badge: 'NEW',
    badgeColor: 'bg-blue-100 text-blue-800',
    name: 'Sora & Veo Prompt Generator',
    description: 'Write optimized prompts for AI video generation with camera angles, motion, and scene control.',
    link: '/tools/video-ai-generation'
  },
  {
    badge: 'NEW',
    badgeColor: 'bg-blue-100 text-blue-800',
    name: 'Instagram Aesthetic Generator',
    description: 'Generate copy-pasteable aesthetic prompts for any Instagram visual style.',
    link: '/tools/instagram-aesthetic-generator'
  }
];
---

<BaseLayout seo={seo}>
  <AstroHeader />

  <div class="max-w-6xl mx-auto px-4 py-16">
    <!-- Section 1: Hero -->
    <div class="text-center mb-16">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        AI Tools for Content Creators
      </h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto mb-8">
        Turn YouTube videos into blog posts and LinkedIn content. Expand prompts. Reverse engineer AI images. All in seconds.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/pricing"
          class="px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors"
        >
          See pricing
        </a>
        <a
          href="/generators"
          class="px-6 py-3 border-2 border-gray-300 text-gray-700 font-semibold rounded-lg hover:border-gray-400 hover:bg-gray-50 transition-colors"
        >
          Browse free generators
        </a>
      </div>
    </div>

    <!-- Section 2: Tool Cards Grid -->
    <div class="mb-16">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-6">
        Available tools
      </p>

      <div class="grid md:grid-cols-2 gap-6">
        {tools.map((tool) => (
          <a
            href={tool.link}
            class="group bg-white border border-gray-200 rounded-xl p-6 hover:shadow-lg hover:border-blue-300 transition-all duration-200"
          >
            <div class="flex items-start justify-between mb-3">
              <span class={`text-xs font-bold px-2.5 py-1 rounded ${tool.badgeColor}`}>
                {tool.badge}
              </span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-blue-600 transition-colors">
              {tool.name}
            </h3>
            <p class="text-gray-600 mb-4 text-sm leading-relaxed">
              {tool.description}
            </p>
            <span class="inline-flex items-center text-blue-600 font-semibold text-sm group-hover:gap-2 transition-all">
              Try it
              <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>

    <!-- Section 3: Free Generators Callout -->
    <div class="border border-gray-200 rounded-xl p-8 text-center">
      <h2 class="text-2xl font-bold text-gray-900 mb-3">
        Looking for free prompt generators?
      </h2>
      <p class="text-gray-600 mb-6 max-w-2xl mx-auto">
        Random Prompts has 40+ free generators for writers, artists, and creatives. No account needed.
      </p>
      <a
        href="/generators"
        class="inline-flex items-center gap-2 px-6 py-3 border-2 border-gray-300 text-gray-700 font-semibold rounded-lg hover:border-gray-400 hover:bg-gray-50 transition-colors"
      >
        Browse free generators
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>

  <AstroFooter />
</BaseLayout>
