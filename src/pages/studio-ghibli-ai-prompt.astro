---
import BaseLayout from '../layouts/BaseLayout.astro';
import AstroHeader from '../components/AstroHeader.astro';
import AstroFooter from '../components/AstroFooter.astro';
import '../styles/global.css';

const seo = {
  path: 'studio-ghibli-ai-prompt',
  title: 'Studio Ghibli AI Prompt (Anime Art Generator)',
  description: 'Create magical Studio Ghibli-style AI art with optimized prompts. Copy ready-to-use prompts for Miyazaki-inspired anime scenes and characters.',
  keywords: 'studio ghibli ai prompt, ghibli style prompt, miyazaki ai art prompt, anime ghibli prompt, ghibli aesthetic prompt, totoro style ai prompt'
};

const prompts = [
  {
    name: "Enchanted Forest Scene",
    prompt: "Studio Ghibli style illustration of a young girl walking through an enchanted forest, massive ancient trees with glowing moss, soft dappled sunlight filtering through leaves, Miyazaki aesthetic, hand-painted anime background, gentle watercolor textures, magical atmosphere, Totoro forest vibes, peaceful serene mood.",
    color: "green"
  },
  {
    name: "Flying Castle in Clouds",
    prompt: "Studio Ghibli artwork of a floating castle among fluffy clouds at golden hour, intricate steampunk architecture with gardens, birds flying around towers, Howl's Moving Castle inspired, dramatic sky with pink and orange hues, hand-drawn anime style, detailed mechanical elements, dreamy atmosphere.",
    color: "sky"
  },
  {
    name: "Seaside Village",
    prompt: "Ghibli-style seaside fishing village, colorful houses on hillside overlooking calm ocean, boats in harbor, children playing on cobblestone streets, Ponyo aesthetic, warm afternoon light, cumulus clouds, hand-painted anime background art, nostalgic peaceful atmosphere.",
    color: "blue"
  },
  {
    name: "Spirit Bathhouse",
    prompt: "Studio Ghibli illustration of a traditional Japanese bathhouse at night, warm lantern light glowing from windows, spirits and yokai gathering outside, Spirited Away inspired, detailed wooden architecture, misty atmosphere, magical nighttime scene, hand-drawn anime style.",
    color: "amber"
  },
  {
    name: "Countryside Train Ride",
    prompt: "Ghibli anime scene of a vintage train traveling through lush countryside, rice paddies and mountains in background, passenger looking out window at sunset, Miyazaki aesthetic, soft watercolor sky, detailed landscape, peaceful journey, nostalgic rural Japan.",
    color: "emerald"
  },
  {
    name: "Garden Spirit Friend",
    prompt: "Studio Ghibli style illustration of a child meeting a friendly forest spirit in an overgrown garden, ancient stone statue covered in moss, butterflies and fireflies, Totoro-inspired creature design, magical realism, soft afternoon light, heartwarming atmosphere.",
    color: "lime"
  },
  {
    name: "Sky Pirates Airship",
    prompt: "Ghibli artwork of a retro-futuristic airship flying over mountains, detailed brass and wood construction, crew on deck, Laputa/Castle in the Sky inspired, dramatic cloud formations, adventure atmosphere, hand-painted anime background, golden hour lighting.",
    color: "orange"
  },
  {
    name: "Witch's Cottage",
    prompt: "Studio Ghibli illustration of a cozy witch's cottage in flower meadow, herbs drying outside, black cat on windowsill, Kiki's Delivery Service aesthetic, cottage-core vibes, wildflowers everywhere, soft morning light, hand-drawn anime style, magical everyday life.",
    color: "pink"
  },
  {
    name: "Ancient Forest God",
    prompt: "Ghibli-style majestic forest spirit, towering ethereal being made of trees and flowers, deer-like face with glowing eyes, Princess Mononoke inspired, mystical atmosphere, shafts of light through canopy, detailed nature elements, awe-inspiring presence.",
    color: "teal"
  },
  {
    name: "Rainy City Street",
    prompt: "Studio Ghibli urban scene of a rainy evening in Japanese city, neon signs reflecting on wet pavement, person with umbrella waiting at bus stop, Whisper of the Heart atmosphere, detailed storefronts, cozy lighting from shops, nostalgic modern Japan.",
    color: "indigo"
  },
  {
    name: "Flying Fish Migration",
    prompt: "Ghibli anime illustration of massive flying fish soaring over ocean at dawn, child on boat reaching up in wonder, magical realism, Ponyo-inspired fantasy, beautiful pastel sky, sparkling water, sense of wonder and adventure, hand-painted style.",
    color: "cyan"
  },
  {
    name: "Abandoned Robot Garden",
    prompt: "Studio Ghibli scene of a gentle giant robot overgrown with flowers in ancient garden, birds nesting in its joints, Laputa guardian inspired, peaceful decay, nature reclaiming technology, soft diffused light, bittersweet atmosphere, detailed mechanical and organic elements.",
    color: "rose"
  },
  {
    name: "Mountain Hot Spring",
    prompt: "Ghibli-style mountain onsen at twilight, steam rising from natural hot spring, snow-capped peaks in distance, traditional wooden bath house, lanterns glowing warmly, winter evening atmosphere, peaceful solitude, detailed Japanese architecture, Spirited Away aesthetic.",
    color: "purple"
  },
  {
    name: "Cat Bus Stop",
    prompt: "Studio Ghibli illustration of magical cat-shaped bus arriving at countryside stop on rainy night, child with umbrella waiting, glowing headlight eyes, Totoro inspired, whimsical fantasy, detailed rain effects, warm light from bus windows, nighttime magic.",
    color: "yellow"
  },
  {
    name: "Floating Islands",
    prompt: "Ghibli artwork of floating islands connected by rope bridges, waterfalls cascading into clouds below, ancient temples and gardens on each island, Laputa inspired, epic scale, adventure atmosphere, detailed vegetation, dramatic cloud sea, golden hour light.",
    color: "violet"
  }
];
---

<BaseLayout seo={seo}>
  <AstroHeader />

  <!-- Hero Section -->
  <div class="bg-gradient-to-br from-green-500 via-teal-500 to-sky-600 text-white py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">
        Studio Ghibli AI Prompt Generator
      </h1>
      <p class="text-xl text-green-100 max-w-2xl mx-auto">
        Create magical Studio Ghibli-style AI artwork with our optimized prompts. Generate Miyazaki-inspired scenes, enchanted landscapes, and whimsical characters using AI image generators.
      </p>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 py-12">

    <!-- What is Section -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">What is a Studio Ghibli AI Prompt?</h2>
      <p class="text-gray-700 mb-4">
        A Studio Ghibli AI prompt is a carefully crafted text instruction that captures the magical, hand-painted aesthetic of Hayao Miyazaki's beloved anime films. These prompts combine references to Ghibli's signature elements - enchanted forests, flying machines, friendly spirits, and nostalgic Japanese settings - with technical art direction to guide AI generators.
      </p>
      <p class="text-gray-700 mb-4">
        The Ghibli style is characterized by detailed hand-painted backgrounds, soft watercolor textures, magical realism, and a unique blend of whimsy and environmental themes. Films like Spirited Away, My Neighbor Totoro, Howl's Moving Castle, and Princess Mononoke define this iconic aesthetic.
      </p>
      <p class="text-gray-700">
        These prompts work with Midjourney, DALL-E, Stable Diffusion, and other AI art generators to create images that capture the warmth, wonder, and artistry of Studio Ghibli's animation legacy.
      </p>
    </section>

    <!-- Prompt Structure -->
    <section class="mb-12 bg-gradient-to-r from-green-50 to-teal-50 rounded-2xl p-8 border border-green-200">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Studio Ghibli Prompt Structure</h2>
      <p class="text-gray-700 mb-4">Follow this structure for authentic Ghibli-style results:</p>
      <div class="bg-white rounded-lg p-6 border border-green-300 mb-6 font-mono text-sm text-gray-800">
        Studio Ghibli [style/illustration] of [scene description], [specific Ghibli film reference], [lighting mood], [atmosphere keywords], hand-painted anime [style], [emotional tone].
      </div>
      <div class="grid md:grid-cols-2 gap-4">
        <div>
          <h3 class="font-semibold text-gray-900 mb-2">Essential Ghibli Elements:</h3>
          <ul class="list-disc list-inside text-gray-700 space-y-1 text-sm">
            <li>Nature and environmental themes</li>
            <li>Magical creatures and spirits</li>
            <li>Detailed hand-painted backgrounds</li>
            <li>Nostalgic, peaceful atmosphere</li>
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 mb-2">Style Keywords:</h3>
          <ul class="list-disc list-inside text-gray-700 space-y-1 text-sm">
            <li>"Miyazaki aesthetic"</li>
            <li>"Hand-painted anime style"</li>
            <li>"Soft watercolor textures"</li>
            <li>"Magical realism"</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Prompts Grid -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">15 Magical Studio Ghibli AI Prompts</h2>
      <p class="text-center text-gray-600 mb-8">Click any prompt to copy it to your clipboard</p>

      <div class="space-y-4">
        {prompts.map((item, index) => (
          <div class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-lg transition-shadow">
            <div class="flex items-start justify-between gap-4 mb-3">
              <h3 class="text-lg font-bold text-gray-900">
                <span class="text-green-600">{index + 1}.</span> {item.name}
              </h3>
              <button
                class="copy-btn flex-shrink-0 px-4 py-2 bg-green-600 text-white text-sm font-medium rounded-lg hover:bg-green-700 transition-colors"
                data-text={item.prompt}
              >
                Copy
              </button>
            </div>
            <p class="text-gray-700 text-sm leading-relaxed">{item.prompt}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- How to Improve -->
    <section class="mb-12 bg-gradient-to-r from-amber-50 to-yellow-50 rounded-2xl p-8 border border-amber-200">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">How to Improve Your Ghibli AI Art</h2>
      <p class="text-gray-700 mb-4">Enhance your Ghibli-style generations with these techniques:</p>
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <h3 class="font-semibold text-gray-900 mb-2">Reference Specific Films:</h3>
          <ul class="list-disc list-inside text-gray-700 space-y-2 text-sm">
            <li>Totoro - forest spirits, rural Japan</li>
            <li>Spirited Away - bathhouse, spirits</li>
            <li>Howl's Castle - steampunk, flying</li>
            <li>Mononoke - nature gods, epic scale</li>
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 mb-2">Add Atmosphere Keywords:</h3>
          <ul class="list-disc list-inside text-gray-700 space-y-2 text-sm">
            <li><code class="bg-white px-2 py-0.5 rounded">"nostalgic peaceful mood"</code></li>
            <li><code class="bg-white px-2 py-0.5 rounded">"dappled sunlight"</code></li>
            <li><code class="bg-white px-2 py-0.5 rounded">"magical everyday life"</code></li>
            <li><code class="bg-white px-2 py-0.5 rounded">"sense of wonder"</code></li>
          </ul>
        </div>
      </div>
      <p class="text-gray-700 mt-6">
        Expand simple ideas into detailed Ghibli prompts with our <a href="/tools/text-to-prompt" class="text-green-600 hover:underline font-medium">Text to Prompt Expander</a> tool.
      </p>
    </section>

    <!-- FAQ Section -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Frequently Asked Questions</h2>
      <div class="space-y-4">
        <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Which AI tool creates the best Studio Ghibli art?</h3>
          <p class="text-gray-700">
            Midjourney V6 currently produces the most authentic Ghibli-style results with its strong understanding of anime aesthetics. DALL-E 3 and Stable Diffusion with anime-trained models also work well when given detailed prompts.
          </p>
        </div>
        <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">How do I get the hand-painted look?</h3>
          <p class="text-gray-700">
            Include keywords like "hand-painted anime background," "soft watercolor textures," "traditional animation style," and avoid terms like "digital art," "3D render," or "photorealistic" which push toward different aesthetics.
          </p>
        </div>
        <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Can I create Ghibli-style characters?</h3>
          <p class="text-gray-700">
            Yes, focus on Ghibli's character design elements: expressive eyes, simple but emotive faces, practical clothing, and often young protagonists. Reference specific films for character style guidance.
          </p>
        </div>
        <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">What makes Ghibli backgrounds so distinctive?</h3>
          <p class="text-gray-700">
            Ghibli backgrounds feature incredible detail, visible brushstrokes, atmospheric perspective, and careful attention to light and weather. Emphasize "detailed environment," "atmospheric lighting," and specific weather conditions in your prompts.
          </p>
        </div>
      </div>
    </section>

    <!-- Related Tools -->
    <section class="bg-white rounded-2xl border border-gray-200 p-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Related Prompt Tools</h2>
      <div class="grid md:grid-cols-2 gap-4">
        <a href="/tools/text-to-prompt" class="p-4 bg-green-50 rounded-lg hover:bg-green-100 transition-colors">
          <h3 class="font-semibold text-green-900">Text to Prompt Expander</h3>
          <p class="text-sm text-green-700">Transform simple ideas into detailed Ghibli prompts</p>
        </a>
        <a href="/tools/image-to-prompt" class="p-4 bg-purple-50 rounded-lg hover:bg-purple-100 transition-colors">
          <h3 class="font-semibold text-purple-900">Image to Prompt Analyzer</h3>
          <p class="text-sm text-purple-700">Extract style details from Ghibli screenshots</p>
        </a>
        <a href="/art-prompts/anime" class="p-4 bg-pink-50 rounded-lg hover:bg-pink-100 transition-colors">
          <h3 class="font-semibold text-pink-900">Anime Prompt Generator</h3>
          <p class="text-sm text-pink-700">More anime and manga art prompts</p>
        </a>
        <a href="/art-prompts/fantasy-art" class="p-4 bg-indigo-50 rounded-lg hover:bg-indigo-100 transition-colors">
          <h3 class="font-semibold text-indigo-900">Fantasy Art Prompts</h3>
          <p class="text-sm text-indigo-700">Magical landscapes and fantasy scenes</p>
        </a>
      </div>
    </section>
  </div>

  <AstroFooter />

  <!-- Copy functionality -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const copyButtons = document.querySelectorAll('.copy-btn');

      copyButtons.forEach(button => {
        button.addEventListener('click', async () => {
          const text = button.getAttribute('data-text');

          try {
            await navigator.clipboard.writeText(text);
            const originalText = button.textContent;
            button.textContent = 'Copied!';
            button.classList.remove('bg-green-600', 'hover:bg-green-700');
            button.classList.add('bg-emerald-600');

            setTimeout(() => {
              button.textContent = originalText;
              button.classList.remove('bg-emerald-600');
              button.classList.add('bg-green-600', 'hover:bg-green-700');
            }, 2000);
          } catch (err) {
            console.error('Failed to copy:', err);
          }
        });
      });
    });
  </script>
</BaseLayout>
